{% liquid
  assign is_quantity = false
  if block.settings.goal_type == 'quantity'
    assign is_quantity = true
  endif

  if is_quantity
    assign goal_multiplier = 1.0
    assign goal_max_reference = items_count
  else
    assign goal_multiplier = 100.00
    assign goal_max_reference = cart.total_price
  endif

  if block.settings.enable_goal_1
    assign highest_goal = block.settings.goal_1_amount | times: goal_multiplier
  endif
  if block.settings.enable_goal_2
    assign highest_goal = block.settings.goal_2_amount | times: goal_multiplier
  endif
  if block.settings.enable_goal_3
    assign highest_goal = block.settings.goal_3_amount | times: goal_multiplier
  endif

  assign bar_progress = goal_max_reference | divided_by: highest_goal | times: 100.00
  assign all_goals_reached = false
  if bar_progress >= 100.00
    assign all_goals_reached = true
    assign bar_progress = 100
  endif

  assign next_goal_text = null
  if block.settings.enable_goal_1
    assign goal_1_position = block.settings.goal_1_amount | divided_by: highest_goal | times: goal_multiplier | times: 100.00
    if goal_1_position > bar_progress and next_goal_text == null
      assign next_goal_text = block.settings.goal_1_text
      assign next_goal = block.settings.goal_1_amount | times: goal_multiplier
    endif
  endif
  if block.settings.enable_goal_2
    assign goal_2_position = block.settings.goal_2_amount | divided_by: highest_goal | times: goal_multiplier | times: 100.00
    if goal_2_position > bar_progress and next_goal_text == null
      assign next_goal_text = block.settings.goal_2_text
      assign next_goal = block.settings.goal_2_amount | times: goal_multiplier
    endif
  endif
  if block.settings.enable_goal_3
    assign goal_3_position = block.settings.goal_3_amount | divided_by: highest_goal | times: goal_multiplier | times: 100.00
    if goal_3_position > bar_progress and next_goal_text == null
      assign next_goal_text = block.settings.goal_3_text
      assign next_goal = block.settings.goal_3_amount | times: goal_multiplier
    endif
  endif

  assign icon_size = block.settings.icon_size | divided_by: 10.0
  assign icon_scale = block.settings.icon_scale | divided_by: 100.0
  assign icon_corner_radius = block.settings.icon_corner_radius | divided_by: 2.0
  assign border_thickness = block.settings.border_thickness | divided_by: 10.0
  assign line_height = block.settings.line_height | divided_by: 10.0
%}

{% capture goal_difference_html %}
  {% if is_quantity %}
    {{ next_goal | minus: items_count | round }}
  {% else %}
    <span>{{ next_goal | minus: cart.total_price | money_without_trailing_zeros }}</span>
  {% endif %}
{% endcapture %}

<style>
  .cart-checkpoints-{{ block.id }} {
    margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;
    margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;
    --mobile-text-size: {{ block.settings.labels_mobile_text_size | divided_by: 10.0 }}rem;
    --desktop-text-size: {{ block.settings.labels_desktop_text_size | divided_by: 10.0 }}rem;
  }
  .cart-checkpoints-{{ block.id }} .cart-progress__bar {
    height: {{ line_height }}rem;
  }
  .cart-checkpoints-{{ block.id }} .cart-progress__bar__badge {
    width: {{ icon_size }}rem;
    height: {{ icon_size }}rem;
    border-radius: {{ icon_corner_radius }}%;
    {% if block.settings.border_thickness > 0 %}
      border: {{ border_thickness }}rem {{ block.settings.border_style }} {% if block.settings.border_color == 'custom' %}{{ block.settings.border_custom_color }}{% else %}rgb(var(--color-base-{{ block.settings.border_color }})){% endif %};
    {% endif %}
    {% if block.settings.icon_bg == 'custom_color' %}
      background: {{ block.settings.icon_bg_color }};
    {% elsif block.settings.icon_bg == 'gradient' %}
      background: {{ block.settings.icon_bg_gradient }};
    {% else %}
      background: rgb(var(--color-base-{{ block.settings.icon_bg }}));
    {% endif %}
  }
  .cart-checkpoints-{{ block.id }} .cart-progress__bar__badge .material-symbols-outlined,
  .cart-checkpoints-{{ block.id }} .cart-progress__bar__badge img {
    font-size: calc({{ icon_size }}rem * {{ icon_scale }});
    width: calc({{ icon_size }}rem * {{ icon_scale }});
    height: calc({{ icon_size }}rem * {{ icon_scale }});
    {% if block.settings.icon_color == 'custom' %}
      color: {{ block.settings.icon_custom_color }};
    {% else %}
      color: rgb(var(--accent-color));
    {% endif %}
  }
  .cart-checkpoints-{{ block.id }} .cart-checkpoints__icon--dot::before {
    content: '';
    display: block;
    width: calc({{ icon_size }}rem * {{ icon_scale }});
    height: calc({{ icon_size }}rem * {{ icon_scale }});
    border-radius: 50%;
    flex-shrink: 0;
    {% if block.settings.icon_color == 'custom' %}
      background: {{ block.settings.icon_custom_color }};
    {% else %}
      background: rgb(var(--accent-color));
    {% endif %}
  }
  .cart-checkpoints-{{ block.id }} .cart-progress__bar__progress {
    {% unless block.settings.display_stripes %}
      background-image: none !important;
      animation: none !important;
    {% endunless %}
    {% if block.settings.line_color == 'custom_color' %}
      background-color: {{ block.settings.line_custom_color }} !important;
    {% elsif block.settings.line_color == 'gradient' %}
      background: {{ block.settings.line_gradient }} !important;
    {% endif %}
  }
</style>

<div
  class="cart-progress cart-checkpoints cart-checkpoints-{{ block.id }} {% if block.settings.icon_color != 'custom' %}accent-color-{{ block.settings.icon_color }}{% endif %}"
  {{ block.shopify_attributes }}
>
  <p class="cart-progress__text">
    {% if all_goals_reached == false %}
      {{
        block.settings.progress_message
        | replace: '[amount]', goal_difference_html
        | replace: '[next_goal]', next_goal_text
      }}
    {% else %}
      {{ block.settings.success_message }}
    {% endif %}
  </p>
  <div class="cart-progress__bar {% if block.settings.line_color != 'custom_color' and block.settings.line_color != 'gradient' %}accent-color-{{ block.settings.line_color }}{% endif %}">
    <div class="cart-progress__bar__progress{% if block.settings.display_stripes %} cart-progress__bar__progress--striped{% endif %}" style="width: {{ bar_progress }}%;">&nbsp</div>
    {% if block.settings.enable_goal_1 %}
      <div class="cart-progress__bar__badge cart-checkpoints__icon{% if block.settings.goal_1_icon_type == 'dot' %} cart-checkpoints__icon--dot{% endif %}" style="--position:{{ goal_1_position }}%;">
        {% if block.settings.goal_1_icon_type == 'custom_icon' and block.settings.goal_1_custom_icon != blank %}
          <img
            src="{{ block.settings.goal_1_custom_icon | image_url }}"
            {% if block.settings.goal_1_custom_icon.alt != blank %}
              alt="{{ block.settings.goal_1_custom_icon.alt | escape }}"
            {% else %}
              role="presentation"
            {% endif %}
            height="200"
            width="200"
            loading="lazy"
          >
        {% elsif block.settings.goal_1_icon_type == 'icon' and block.settings.goal_1_icon != blank %}
          <span class="material-symbols-outlined{% if block.settings.goal_1_icon_filled %} filled{% endif %}">
            {{ block.settings.goal_1_icon | strip | downcase | replace: ' ', '_' }}
          </span>
        {% elsif block.settings.goal_1_icon_type == 'dot' %}
          {%- comment -%}Dot is rendered via CSS pseudo-element{%- endcomment -%}
        {% endif %}
        {% if block.settings.goal_1_label != blank or block.settings.goal_1_label_2 != blank %}
          <span class="cart-checkpoints__label cart-checkpoints__label--level-one custom-font-size">
            {% if block.settings.goal_1_label != blank %}
              <span>{{ block.settings.goal_1_label }}</span>
            {% endif %}
            {% if block.settings.goal_1_label_2 != blank %}
              <span>{{ block.settings.goal_1_label_2 }}</span>
            {% endif %}
          </span>
        {% endif %}
      </div>
    {% endif %}
    {% if block.settings.enable_goal_2 %}
      <div class="cart-progress__bar__badge cart-checkpoints__icon{% if block.settings.goal_2_icon_type == 'dot' %} cart-checkpoints__icon--dot{% endif %}" style="--position:{{ goal_2_position }}%;">
        {% if block.settings.goal_2_icon_type == 'custom_icon' and block.settings.goal_2_custom_icon != blank %}
          <img
            src="{{ block.settings.goal_2_custom_icon | image_url }}"
            {% if block.settings.goal_2_custom_icon.alt != blank %}
              alt="{{ block.settings.goal_2_custom_icon.alt | escape }}"
            {% else %}
              role="presentation"
            {% endif %}
            height="200"
            width="200"
            loading="lazy"
          >
        {% elsif block.settings.goal_2_icon_type == 'icon' and block.settings.goal_2_icon != blank %}
          <span class="material-symbols-outlined{% if block.settings.goal_2_icon_filled %} filled{% endif %}">
            {{ block.settings.goal_2_icon | strip | downcase | replace: ' ', '_' }}
          </span>
        {% elsif block.settings.goal_2_icon_type == 'dot' %}
          {%- comment -%}Dot is rendered via CSS pseudo-element{%- endcomment -%}
        {% endif %}
        {% if block.settings.goal_2_label != blank or block.settings.goal_2_label_2 != blank %}
          <span class="cart-checkpoints__label cart-checkpoints__label--level-one custom-font-size">
            {% if block.settings.goal_2_label != blank %}
              <span>{{ block.settings.goal_2_label }}</span>
            {% endif %}
            {% if block.settings.goal_2_label_2 != blank %}
              <span>{{ block.settings.goal_2_label_2 }}</span>
            {% endif %}
          </span>
        {% endif %}
      </div>
    {% endif %}
    {% if block.settings.enable_goal_3 %}
      <div class="cart-progress__bar__badge cart-checkpoints__icon{% if block.settings.goal_3_icon_type == 'dot' %} cart-checkpoints__icon--dot{% endif %}" style="--position:{{ goal_3_position }}%;">
        {% if block.settings.goal_3_icon_type == 'custom_icon' and block.settings.goal_3_custom_icon != blank %}
          <img
            src="{{ block.settings.goal_3_custom_icon | image_url }}"
            {% if block.settings.goal_3_custom_icon.alt != blank %}
              alt="{{ block.settings.goal_3_custom_icon.alt | escape }}"
            {% else %}
              role="presentation"
            {% endif %}
            height="200"
            width="200"
            loading="lazy"
          >
        {% elsif block.settings.goal_3_icon_type == 'icon' and block.settings.goal_3_icon != blank %}
          <span class="material-symbols-outlined{% if block.settings.goal_3_icon_filled %} filled{% endif %}">
            {{ block.settings.goal_3_icon | strip | downcase | replace: ' ', '_' }}
          </span>
        {% elsif block.settings.goal_3_icon_type == 'dot' %}
          {%- comment -%}Dot is rendered via CSS pseudo-element{%- endcomment -%}
        {% endif %}
        {% if block.settings.goal_3_label != blank or block.settings.goal_3_label_2 != blank %}
          <span class="cart-checkpoints__label cart-checkpoints__label--level-one custom-font-size">
            {% if block.settings.goal_3_label != blank %}
              <span>{{ block.settings.goal_3_label }}</span>
            {% endif %}
            {% if block.settings.goal_3_label_2 != blank %}
              <span>{{ block.settings.goal_3_label_2 }}</span>
            {% endif %}
          </span>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>
