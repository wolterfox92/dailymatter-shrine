{%- comment -%}
  Renders a small note icon. Custom image (image_picker) wins; otherwise
  falls back to a preset SVG keyed by `icon`.

  Accepts:
    icon  — preset key (string)
    image — image_picker value (image object)
{%- endcomment -%}

{%- if image != blank -%}
  {{ image | image_url: width: 48 | image_tag: width: 24, height: 24, alt: '', loading: 'lazy' }}
{%- else -%}
  {%- case icon -%}
    {%- when 'shield' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 8l9-5 9 5v8l-9 5-9-5V8z" stroke-linejoin="round"/><path d="M3 8l9 5 9-5M12 13v9" stroke-linejoin="round"/></svg>
    {%- when 'bag' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="7" width="18" height="13" rx="3"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2" stroke-linecap="round"/></svg>
    {%- when 'calendar-check' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="4" width="18" height="17" rx="3"/><path d="M3 9h18M8 2v4M16 2v4M8 14l3 3 5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    {%- when 'leaf' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M20 4C12 4 4 10 4 18c0 1 0 2 .5 2 7 0 15-6 15-14V4z" stroke-linejoin="round"/><path d="M4 20c4-6 8-9 14-13" stroke-linecap="round"/></svg>
    {%- when 'spark' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 3v4M12 17v4M3 12h4M17 12h4M6 6l2.5 2.5M15.5 15.5L18 18M6 18l2.5-2.5M15.5 8.5L18 6" stroke-linecap="round"/></svg>
    {%- when 'bottle' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M6 8h12l-1 12H7L6 8z" stroke-linejoin="round"/><path d="M9 8V5a3 3 0 016 0v3" stroke-linecap="round"/></svg>
    {%- when 'scoop' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="9" cy="10" r="4"/><path d="M9 14v7M6 21h6M13 6l7-2-1.5 7-5.5-1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    {%- when 'brain' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 3a6 6 0 00-6 6v4l-2 3h16l-2-3V9a6 6 0 00-6-6z" stroke-linejoin="round"/><path d="M10 20a2 2 0 004 0" stroke-linecap="round"/></svg>
    {%- when 'clock' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    {%- when 'checklist' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="4" y="4" width="16" height="16" rx="3"/><path d="M8 10l2 2 4-4M8 16l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
    {%- else -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="9"/></svg>
  {%- endcase -%}
{%- endif -%}
