{%- style -%}
  .benefit-cards-{{ section.id }} {
    --bc-card-width: {{ section.settings.card_width_mobile }}px;
    --bc-card-radius: {{ section.settings.card_radius }}px;
    --bc-gap: {{ section.settings.card_gap_mobile | divided_by: 10.0 }}rem;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .benefit-cards-{{ section.id }} {
      --bc-card-width: {{ section.settings.card_width_desktop }}px;
      --bc-gap: {{ section.settings.card_gap_desktop | divided_by: 10.0 }}rem;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .benefit-cards__heading {
    text-align: {{ section.settings.heading_alignment }};
    font-size: {{ section.settings.heading_size | divided_by: 10.0 }}rem;
    margin: 0 0 2.4rem;
  }
{%- endstyle -%}

<style>
  .benefit-cards {
    margin: 0 auto;
  }

  .benefit-cards__track {
    display: flex;
    gap: var(--bc-gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.4rem;
  }

  .benefit-cards__track::-webkit-scrollbar {
    display: none;
  }

  .benefit-cards__card {
    position: relative;
    flex: 0 0 var(--bc-card-width);
    aspect-ratio: 267 / 321;
    border-radius: var(--bc-card-radius);
    overflow: hidden;
    scroll-snap-align: start;
    background: rgb(var(--color-background, 255, 255, 255));
    text-decoration: none;
    display: block;
  }

  .benefit-cards__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Parent-scoped selector beats the theme's `div:empty { display: none }` rule. */
  .benefit-cards__card .benefit-cards__overlay {
    display: block;
    position: absolute;
    inset: 0;
    pointer-events: none;
    {%- assign bc_overlay = section.settings.overlay_color | default: '#cac0ff' -%}
    {%- assign bc_overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0 -%}
    background: linear-gradient(
      to bottom,
      {{ bc_overlay | color_modify: 'alpha', 0 }} 35%,
      {{ bc_overlay | color_modify: 'alpha', bc_overlay_alpha }} 100%
    );
  }

  .benefit-cards__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    background: {{ section.settings.badge_background }};
    color: {{ section.settings.badge_text_color }};
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }

  .benefit-cards__title {
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 2.8rem;
    margin: 0;
    color: {{ section.settings.card_text_color }};
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: 2.4rem;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }

  /* Progress slider */
  {%- assign bc_progress = section.settings.progress_color | default: '#25162f' -%}
  .benefit-cards__progress {
    position: relative;
    height: 6px;
    width: 100%;
    max-width: 35.8rem;
    margin: 2rem auto 0;
    border-radius: 56px;
    background: {{ bc_progress | color_modify: 'alpha', 0.15 }};
    cursor: pointer;
    touch-action: none;
  }

  /* Parent-scoped selector beats the theme's `div:empty { display: none }` rule. */
  .benefit-cards__progress .benefit-cards__progress-thumb {
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 30%;
    min-width: 24px;
    border-radius: 56px;
    background: {{ bc_progress }};
    transform: translateX(0);
  }

  .benefit-cards--no-overflow .benefit-cards__progress {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .benefit-cards__track {
      justify-content: {{ section.settings.heading_alignment | replace: 'left', 'flex-start' | replace: 'right', 'flex-end' }};
    }
  }
</style>

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div
      class="benefit-cards benefit-cards-{{ section.id }}"
      data-benefit-cards
    >
      {%- if section.settings.heading != blank -%}
        <h2 class="benefit-cards__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="benefit-cards__track" data-bc-track>
        {%- for block in section.blocks -%}
          {%- liquid
            assign tag = 'div'
            if block.settings.link != blank
              assign tag = 'a'
            endif
          -%}
          <{{ tag }}
            class="benefit-cards__card"
            {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 600
                | image_tag:
                  class: 'benefit-cards__img',
                  loading: 'lazy',
                  widths: '267, 400, 534, 600',
                  sizes: '(min-width: 750px) 300px, 70vw',
                  alt: block.settings.image.alt | default: block.settings.title
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'benefit-cards__img placeholder-svg' }}
            {%- endif -%}

            <div class="benefit-cards__overlay"></div>

            {%- if block.settings.badge != blank -%}
              <span class="benefit-cards__badge">{{ block.settings.badge }}</span>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="benefit-cards__title">{{ block.settings.title }}</h3>
            {%- endif -%}
          </{{ tag }}>
        {%- endfor -%}
      </div>

      <div class="benefit-cards__progress" data-bc-progress>
        <div class="benefit-cards__progress-thumb" data-bc-thumb></div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    function initBenefitCards(root) {
      if (!root || root.dataset.bcInit === 'true') return;
      var track = root.querySelector('[data-bc-track]');
      var progress = root.querySelector('[data-bc-progress]');
      var thumb = root.querySelector('[data-bc-thumb]');
      if (!track || !progress || !thumb) return;
      root.dataset.bcInit = 'true';

      function maxScroll() {
        return track.scrollWidth - track.clientWidth;
      }

      var raf = null;
      function update() {
        var max = maxScroll();
        if (max <= 1) {
          root.classList.add('benefit-cards--no-overflow');
          return;
        }
        root.classList.remove('benefit-cards--no-overflow');
        var ratio = track.clientWidth / track.scrollWidth;
        var thumbWidth = Math.min(Math.max(ratio * 100, 12), 90);
        thumb.style.width = thumbWidth + '%';
        var progress01 = track.scrollLeft / max;
        var travel = progress.clientWidth * (1 - thumbWidth / 100);
        thumb.style.transform = 'translateX(' + progress01 * travel + 'px)';
      }
      function requestUpdate() {
        if (raf) return;
        raf = requestAnimationFrame(function () {
          raf = null;
          update();
        });
      }

      track.addEventListener('scroll', requestUpdate, { passive: true });
      window.addEventListener('resize', requestUpdate);

      // Recalculate when card images finish loading (they change scrollWidth).
      root.querySelectorAll('img').forEach(function (img) {
        if (!img.complete) img.addEventListener('load', requestUpdate);
      });

      // Keep in sync if the layout changes for any reason.
      if ('ResizeObserver' in window) {
        new ResizeObserver(requestUpdate).observe(track);
      }

      // Drag the progress thumb to scroll the cards.
      var dragging = false;

      function scrollFromPointer(clientX) {
        var rect = progress.getBoundingClientRect();
        var thumbWidthPx = thumb.getBoundingClientRect().width;
        var usable = rect.width - thumbWidthPx;
        var x = clientX - rect.left - thumbWidthPx / 2;
        var pct = usable > 0 ? Math.min(Math.max(x / usable, 0), 1) : 0;
        track.scrollLeft = pct * maxScroll();
      }

      progress.addEventListener('pointerdown', function (e) {
        dragging = true;
        progress.setPointerCapture(e.pointerId);
        scrollFromPointer(e.clientX);
      });
      progress.addEventListener('pointermove', function (e) {
        if (dragging) scrollFromPointer(e.clientX);
      });
      progress.addEventListener('pointerup', function () {
        dragging = false;
      });
      progress.addEventListener('pointercancel', function () {
        dragging = false;
      });

      update();
      // scrollWidth can settle slightly after first paint / fonts / images.
      window.addEventListener('load', update);
      setTimeout(update, 300);
    }

    function initAll(scope) {
      (scope || document).querySelectorAll('[data-benefit-cards]').forEach(initBenefitCards);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () { initAll(); });
    } else {
      initAll();
    }

    // Re-init inside the theme editor when the section is reloaded.
    document.addEventListener('shopify:section:load', function (e) {
      e.target.querySelectorAll('[data-benefit-cards]').forEach(function (el) {
        el.dataset.bcInit = '';
        initBenefitCards(el);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Benefit cards",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Benefits for everybody"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 40
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "range",
      "id": "card_width_mobile",
      "min": 200,
      "max": 300,
      "step": 1,
      "unit": "px",
      "label": "Card width (mobile)",
      "default": 267
    },
    {
      "type": "range",
      "id": "card_width_desktop",
      "min": 220,
      "max": 420,
      "step": 2,
      "unit": "px",
      "label": "Card width (desktop)",
      "default": 300
    },
    {
      "type": "range",
      "id": "card_gap_mobile",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Gap between cards (mobile)",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_gap_desktop",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Gap between cards (desktop)",
      "default": 24
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Card corner radius",
      "default": 24
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text color",
      "default": "#25162f"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Image overlay color",
      "default": "#cac0ff"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image overlay opacity",
      "default": 100
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "color",
      "id": "badge_background",
      "label": "Badge background",
      "default": "#cac0ff"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text",
      "default": "#25162f"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "color",
      "id": "progress_color",
      "label": "Progress bar color",
      "default": "#25162f"
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "inverse", "label": "Inverse" }
      ],
      "default": "background-1",
      "label": "Color scheme"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge label",
          "default": "Lorem ipsum"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Show up with lorem ipsum"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Benefit cards",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
