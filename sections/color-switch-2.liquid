{%- style -%}
  .color-switch-{{ section.id }} {
    --cs-radius: {{ section.settings.image_radius }}px;
    --cs-btn-radius: {{ section.settings.button_radius }}px;
    --cs-gap: {{ section.settings.button_gap | divided_by: 10.0 }}rem;
    --cs-active-bg: {{ section.settings.button_active_background }};
    --cs-active-text: {{ section.settings.button_active_text }};
    --cs-inactive-text: {{ section.settings.button_inactive_text }};
    --cs-inactive-border: {{ section.settings.button_inactive_border }};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .color-switch-{{ section.id }} .color-switch__heading {
    font-size: {{ section.settings.heading_size | times: 0.85 | round: 0 | divided_by: 10.0 }}rem;
  }

  @media screen and (min-width: 750px) {
    .color-switch-{{ section.id }} .color-switch__heading {
      font-size: {{ section.settings.heading_size | divided_by: 10.0 }}rem;
    }
  }
{%- endstyle -%}

<style>
  .color-switch {
    margin: 0 auto;
    max-width: {{ section.settings.max_width }}px;
  }

  .color-switch__heading {
    text-align: center;
    margin: 0 0 2.4rem;
    font-family: var(--font-heading-family);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: {{ section.settings.heading_color }};
  }

  /* Stacked, full-width buttons */
  .color-switch__buttons {
    display: flex;
    flex-direction: column;
    gap: var(--cs-gap);
    margin-bottom: 2.4rem;
  }

  .color-switch__btn {
    appearance: none;
    cursor: pointer;
    width: 100%;
    min-height: 4rem;
    padding: 1rem 1.6rem;
    border: 1px solid var(--cs-inactive-border);
    border-radius: var(--cs-btn-radius);
    background: transparent;
    color: var(--cs-inactive-text);
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: 1.4rem;
    line-height: 1;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    text-align: center;
    transition: background-color 0.25s ease, color 0.25s ease, border-color 0.25s ease, transform 0.15s ease;
  }

  .color-switch__btn:hover {
    border-color: {{ section.settings.button_inactive_text | color_modify: 'alpha', 0.45 }};
  }

  .color-switch__btn:active {
    transform: scale(0.99);
  }

  /* Active state: only the selected button gets the accent color. */
  .color-switch__btn.is-active {
    background: var(--cs-active-bg);
    color: var(--cs-active-text);
    border-color: transparent;
  }

  /* Image stage */
  .color-switch__stage {
    position: relative;
    border-radius: var(--cs-radius);
    overflow: hidden;
    background: {{ section.settings.stage_background }};
    aspect-ratio: {{ section.settings.image_ratio }};
  }

  .color-switch__panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s ease;
  }

  .color-switch__panel.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .color-switch__panel img,
  .color-switch__panel .placeholder-svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_fit }};
  }

  /* Text + subtext overlaid on the bottom of the image. */
  .color-switch__overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    margin: 0;
    padding: 6rem 2.4rem 2.4rem;
    color: {{ section.settings.overlay_text_color }};
    background: linear-gradient(
      to top,
      {{ section.settings.overlay_gradient_color | color_modify: 'alpha', 0.85 }},
      {{ section.settings.overlay_gradient_color | color_modify: 'alpha', 0 }}
    );
  }

  .color-switch__overlay-title {
    margin: 0 0 0.6rem;
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: 2.2rem;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .color-switch__overlay-text {
    margin: 0;
    font-size: 1.5rem;
    line-height: 1.45;
    letter-spacing: -0.01em;
    color: {{ section.settings.overlay_text_color | color_modify: 'alpha', 0.9 }};
  }

  /* Desktop: text + buttons in a left column, image in a right column. */
  @media screen and (min-width: 990px) {
    .color-switch {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      column-gap: {{ section.settings.column_gap | divided_by: 10.0 }}rem;
    }

    .color-switch--img-left .color-switch__content {
      order: 2;
    }

    .color-switch--img-left .color-switch__stage {
      order: 1;
    }

    .color-switch__content {
      min-width: 0;
    }

    .color-switch__heading {
      text-align: left;
    }

    .color-switch__buttons {
      display: grid;
      grid-template-columns: 1fr 1fr;
      margin-bottom: 0;
    }

    .color-switch__stage {
      margin: 0;
    }
  }
</style>

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div
      class="color-switch color-switch-{{ section.id }} color-switch--img-{{ section.settings.image_position }}"
      data-color-switch
    >
      <div class="color-switch__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="color-switch__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="color-switch__buttons" role="tablist">
            {%- for block in section.blocks -%}
              <button
                type="button"
                role="tab"
                class="color-switch__btn{% if forloop.first %} is-active{% endif %}"
                data-cs-btn="{{ forloop.index0 }}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                aria-controls="cs-panel-{{ section.id }}-{{ forloop.index0 }}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.label | default: 'Option' }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="color-switch__stage">
          {%- for block in section.blocks -%}
            <div
              class="color-switch__panel{% if forloop.first %} is-active{% endif %}"
              id="cs-panel-{{ section.id }}-{{ forloop.index0 }}"
              data-cs-panel="{{ forloop.index0 }}"
              role="tabpanel"
              {% unless forloop.first %}hidden{% endunless %}
            >
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 1400
                  | image_tag:
                    loading: 'lazy',
                    widths: '350, 535, 750, 1070, 1400',
                    sizes: '(min-width: 990px) 600px, 100vw',
                    alt: block.settings.label
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}

              {%- if block.settings.overlay_title != blank or block.settings.overlay_text != blank -%}
                <div class="color-switch__overlay">
                  {%- if block.settings.overlay_title != blank -%}
                    <p class="color-switch__overlay-title">{{ block.settings.overlay_title }}</p>
                  {%- endif -%}
                  {%- if block.settings.overlay_text != blank -%}
                    <p class="color-switch__overlay-text">{{ block.settings.overlay_text }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function () {
    function initColorSwitch(root) {
      if (!root || root.dataset.csInit === 'true') return;
      root.dataset.csInit = 'true';

      var buttons = Array.prototype.slice.call(root.querySelectorAll('[data-cs-btn]'));
      var panels = Array.prototype.slice.call(root.querySelectorAll('[data-cs-panel]'));
      if (!buttons.length) return;

      function select(index) {
        buttons.forEach(function (btn) {
          var active = btn.getAttribute('data-cs-btn') === String(index);
          btn.classList.toggle('is-active', active);
          btn.setAttribute('aria-selected', active ? 'true' : 'false');
        });

        panels.forEach(function (panel) {
          var active = panel.getAttribute('data-cs-panel') === String(index);
          panel.classList.toggle('is-active', active);
          if (active) {
            panel.removeAttribute('hidden');
          } else {
            panel.setAttribute('hidden', '');
          }
        });
      }

      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          select(btn.getAttribute('data-cs-btn'));
        });
      });
    }

    function initAll(scope) {
      (scope || document).querySelectorAll('[data-color-switch]').forEach(initColorSwitch);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () { initAll(); });
    } else {
      initAll();
    }

    document.addEventListener('shopify:section:load', function (e) {
      e.target.querySelectorAll('[data-color-switch]').forEach(function (el) {
        el.dataset.csInit = '';
        initColorSwitch(el);
      });
    });
  })();
</script>

