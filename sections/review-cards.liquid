{%- style -%}
  .review-cards-{{ section.id }} {
    --rc-card-width: {{ section.settings.card_width_mobile }}px;
    --rc-card-radius: {{ section.settings.card_radius }}px;
    --rc-gap: {{ section.settings.card_gap_mobile | divided_by: 10.0 }}rem;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .review-cards-{{ section.id }} {
      --rc-card-width: {{ section.settings.card_width_desktop }}px;
      --rc-gap: {{ section.settings.card_gap_desktop | divided_by: 10.0 }}rem;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .review-cards__heading {
    text-align: center;
    font-size: {{ section.settings.heading_size | divided_by: 10.0 }}rem;
    margin: 0.8rem 0 2.4rem;
  }
{%- endstyle -%}

<style>
  .review-cards {
    margin: 0 auto;
  }

  /* Summary row */
  .review-cards__summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.2rem;
    flex-wrap: wrap;
  }

  .review-cards__stars {
    display: inline-flex;
    align-items: center;
    gap: 0;
  }

  .review-cards__stars svg {
    width: 1.6rem;
    height: 1.6rem;
    display: block;
    color: {{ section.settings.star_color }};
  }

  .review-cards__summary-text {
    margin: 0;
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
  }

  .review-cards__summary-text .review-cards__dot {
    color: {{ section.settings.star_color }};
    padding: 0 0.4rem;
  }

  .review-cards__heading {
    color: {{ section.settings.heading_color }};
    font-family: var(--font-heading-family);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }

  /* Track */
  .review-cards__track {
    display: flex;
    gap: var(--rc-gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.4rem;
  }

  .review-cards__track::-webkit-scrollbar {
    display: none;
  }

  /* Card */
  .review-cards__card {
    position: relative;
    flex: 0 0 var(--rc-card-width);
    display: flex;
    flex-direction: column;
    min-height: 35.6rem;
    border-radius: var(--rc-card-radius);
    overflow: hidden;
    scroll-snap-align: start;
    padding: 1.4rem;
    background: {{ section.settings.card_background }};
    color: {{ section.settings.card_text_color }};
  }

  .review-cards__card-stars {
    display: inline-flex;
    align-items: center;
    margin-bottom: 1.8rem;
  }

  .review-cards__card-stars svg {
    width: 1.6rem;
    height: 1.6rem;
    display: block;
    color: {{ section.settings.star_color }};
  }

  .review-cards__card-title {
    margin: 0 0 0.8rem;
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: 1.6rem;
    line-height: 1;
    letter-spacing: -0.01em;
    color: {{ section.settings.card_text_color }};
  }

  .review-cards__card-body {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: {{ section.settings.card_text_color | color_modify: 'alpha', 0.8 }};
  }

  .review-cards__card-author {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    margin-top: 1.6rem;
  }

  .review-cards__card-name {
    margin: 0;
    font-weight: 700;
    font-size: 1.4rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: {{ section.settings.card_text_color }};
    white-space: nowrap;
  }

  .review-cards__verified {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.4rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: {{ section.settings.card_text_color }};
    white-space: nowrap;
  }

  .review-cards__verified svg {
    width: 1.6rem;
    height: 1.6rem;
    display: block;
    color: {{ section.settings.verified_color }};
    flex-shrink: 0;
  }

  /* "Reviewed product" pill */
  .review-cards__product {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: auto;
    padding: 0.7rem;
    border-radius: 0.8rem;
    background: {{ section.settings.pill_background }};
  }

  .review-cards__product-img {
    flex: 0 0 auto;
    width: 4.4rem;
    height: 4.4rem;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 0.4rem;
  }

  .review-cards__product-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
    flex: 1 1 auto;
  }

  .review-cards__product-label {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: {{ section.settings.card_text_color | color_modify: 'alpha', 0.7 }};
  }

  .review-cards__product-name {
    margin: 0;
    font-weight: 700;
    font-size: 1.4rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: {{ section.settings.card_text_color }};
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .review-cards__shop {
    flex: 0 0 auto;
    appearance: none;
    border: 0;
    cursor: pointer;
    min-width: 5.8rem;
    height: 3.6rem;
    padding: 0 1rem;
    border-radius: 0.8rem;
    background: {{ section.settings.shop_button_background }};
    color: {{ section.settings.shop_button_text_color }};
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: 1.1rem;
    line-height: 1;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }

  .review-cards__shop:hover {
    opacity: 0.9;
  }

  .review-cards__shop:active {
    transform: scale(0.97);
  }

  /* Progress slider */
  {%- assign rc_progress = section.settings.progress_color | default: '#25162f' -%}
  .review-cards__progress {
    position: relative;
    height: 6px;
    width: 100%;
    max-width: 35.8rem;
    margin: 2rem auto 0;
    border-radius: 56px;
    background: {{ rc_progress | color_modify: 'alpha', 0.15 }};
    cursor: pointer;
    touch-action: none;
  }

  /* Parent-scoped selector beats the theme's `div:empty { display: none }` rule. */
  .review-cards__progress .review-cards__progress-thumb {
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 30%;
    min-width: 24px;
    border-radius: 56px;
    background: {{ rc_progress }};
    transform: translateX(0);
  }

  .review-cards--no-overflow .review-cards__progress {
    display: none;
  }
</style>

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div
      class="review-cards review-cards-{{ section.id }}"
      data-review-cards
    >
      {%- if section.settings.show_summary -%}
        <div class="review-cards__summary">
          <span class="review-cards__stars" aria-hidden="true">
            {%- for i in (1..5) -%}{%- render 'icon-review-star' -%}{%- endfor -%}
          </span>
          {%- if section.settings.summary_text != blank -%}
            <p class="review-cards__summary-text">{{ section.settings.summary_text }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="review-cards__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="review-cards__track" data-rc-track>
        {%- for block in section.blocks -%}
          {%- assign rating = block.settings.rating | default: 5 -%}
          <div class="review-cards__card" {{ block.shopify_attributes }}>
            <span class="review-cards__card-stars" aria-label="{{ rating }} out of 5 stars">
              {%- for i in (1..rating) -%}{%- render 'icon-review-star' -%}{%- endfor -%}
            </span>

            {%- if block.settings.title != blank -%}
              <h3 class="review-cards__card-title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.body != blank -%}
              <p class="review-cards__card-body">{{ block.settings.body }}</p>
            {%- endif -%}

            <div class="review-cards__card-author">
              {%- if block.settings.author != blank -%}
                <p class="review-cards__card-name">{{ block.settings.author }}</p>
              {%- endif -%}
              {%- if block.settings.verified -%}
                <span class="review-cards__verified">
                  {%- render 'icon-review-verified' -%}
                  {{ block.settings.verified_label }}
                </span>
              {%- endif -%}
            </div>

            {%- if block.settings.product_name != blank or block.settings.product_image != blank -%}
              <div class="review-cards__product">
                {%- if block.settings.product_image != blank -%}
                  {{
                    block.settings.product_image
                    | image_url: width: 120
                    | image_tag:
                      class: 'review-cards__product-img',
                      loading: 'lazy',
                      widths: '34, 68, 102',
                      sizes: '34px',
                      alt: block.settings.product_name
                  }}
                {%- endif -%}
                <div class="review-cards__product-info">
                  <p class="review-cards__product-label">{{ block.settings.product_label }}</p>
                  <p class="review-cards__product-name">{{ block.settings.product_name }}</p>
                </div>
                <button
                  type="button"
                  class="review-cards__shop"
                  data-rc-shop
                >
                  {{ section.settings.shop_button_label }}
                </button>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      <div class="review-cards__progress" data-rc-progress>
        <div class="review-cards__progress-thumb" data-rc-thumb></div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    function scrollToPackBuilder(selector) {
      var target =
        document.querySelector(selector || 'pack-builder') ||
        document.querySelector('.pack-builder');
      if (!target) return;
      if (typeof target.setMode === 'function') {
        target.setMode('subscription');
      }
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function initReviewCards(root) {
      if (!root || root.dataset.rcInit === 'true') return;
      var track = root.querySelector('[data-rc-track]');
      var progress = root.querySelector('[data-rc-progress]');
      var thumb = root.querySelector('[data-rc-thumb]');
      if (!track) return;
      root.dataset.rcInit = 'true';

      // Shop buttons scroll to the pack builder so the visitor can build a pack.
      root.querySelectorAll('[data-rc-shop]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          scrollToPackBuilder(root.dataset.rcPackBuilder);
        });
      });

      if (!progress || !thumb) return;

      function maxScroll() {
        return track.scrollWidth - track.clientWidth;
      }

      var raf = null;
      function update() {
        var max = maxScroll();
        if (max <= 1) {
          root.classList.add('review-cards--no-overflow');
          return;
        }
        root.classList.remove('review-cards--no-overflow');
        var ratio = track.clientWidth / track.scrollWidth;
        var thumbWidth = Math.min(Math.max(ratio * 100, 12), 90);
        thumb.style.width = thumbWidth + '%';
        var progress01 = track.scrollLeft / max;
        var travel = progress.clientWidth * (1 - thumbWidth / 100);
        thumb.style.transform = 'translateX(' + progress01 * travel + 'px)';
      }
      function requestUpdate() {
        if (raf) return;
        raf = requestAnimationFrame(function () {
          raf = null;
          update();
        });
      }

      track.addEventListener('scroll', requestUpdate, { passive: true });
      window.addEventListener('resize', requestUpdate);

      // Recalculate when card images finish loading (they change scrollWidth).
      root.querySelectorAll('img').forEach(function (img) {
        if (!img.complete) img.addEventListener('load', requestUpdate);
      });

      if ('ResizeObserver' in window) {
        new ResizeObserver(requestUpdate).observe(track);
      }

      // Drag the progress thumb to scroll the cards.
      var dragging = false;

      function scrollFromPointer(clientX) {
        var rect = progress.getBoundingClientRect();
        var thumbWidthPx = thumb.getBoundingClientRect().width;
        var usable = rect.width - thumbWidthPx;
        var x = clientX - rect.left - thumbWidthPx / 2;
        var pct = usable > 0 ? Math.min(Math.max(x / usable, 0), 1) : 0;
        track.scrollLeft = pct * maxScroll();
      }

      progress.addEventListener('pointerdown', function (e) {
        dragging = true;
        progress.setPointerCapture(e.pointerId);
        scrollFromPointer(e.clientX);
      });
      progress.addEventListener('pointermove', function (e) {
        if (dragging) scrollFromPointer(e.clientX);
      });
      progress.addEventListener('pointerup', function () {
        dragging = false;
      });
      progress.addEventListener('pointercancel', function () {
        dragging = false;
      });

      update();
      window.addEventListener('load', update);
      setTimeout(update, 300);
    }

    function initAll(scope) {
      (scope || document).querySelectorAll('[data-review-cards]').forEach(initReviewCards);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () { initAll(); });
    } else {
      initAll();
    }

    document.addEventListener('shopify:section:load', function (e) {
      e.target.querySelectorAll('[data-review-cards]').forEach(function (el) {
        el.dataset.rcInit = '';
        initReviewCards(el);
      });
    });
  })();
</script>

{% schema %}
