{%- liquid
  assign chosen_product = section.settings.product
  if chosen_product == blank and template.name == 'product'
    assign chosen_product = product
  endif
  assign product = chosen_product
  assign tier_qty = section.settings.tier_qty | default: 1
  assign tier_pct = section.settings.tier_pct | default: 16
  assign sticks_per_pack = section.settings.sticks_per_pack | default: 30

  assign price_source = section.settings.price_source
  assign stack_was_cents = 0
  assign stack_total_cents = 0
  if price_source == 'product' and product != blank
    assign base_variant_price = product.selected_or_first_available_variant.price
    assign stack_was_cents = base_variant_price | times: tier_qty
    assign discount_factor = 100 | minus: tier_pct
    assign stack_total_cents = stack_was_cents | times: discount_factor | divided_by: 100
  else
    assign stack_total_cents = section.settings.stack_total_manual | times: 100
    assign stack_was_manual = section.settings.stack_was_manual | default: 0
    assign stack_was_cents = stack_was_manual | times: 100
  endif

  assign total_sticks = tier_qty | times: sticks_per_pack
  assign stack_per_day_cents = 0
  if total_sticks > 0
    assign stack_per_day_cents = stack_total_cents | divided_by: total_sticks | round
  endif

  assign alt_total_cents = 0
  for block in section.blocks
    if block.type == 'alt_item'
      assign item_price_cents = block.settings.price | times: 100
      assign alt_total_cents = alt_total_cents | plus: item_price_cents
    endif
  endfor

  assign alt_per_day_cents = 0
  if total_sticks > 0 and alt_total_cents > 0
    assign alt_per_day_cents = alt_total_cents | divided_by: total_sticks | round
  endif

  assign savings_cents = alt_total_cents | minus: stack_total_cents
  assign savings_pct = 0
  if alt_total_cents > 0 and savings_cents > 0
    assign savings_pct = savings_cents | times: 100 | divided_by: alt_total_cents | round
  endif

  assign stack_price_display = stack_total_cents | money_without_trailing_zeros
  assign stack_was_display = stack_was_cents | money_without_trailing_zeros
  assign stack_per_day_display = stack_per_day_cents | money
  assign alt_price_display = alt_total_cents | money_without_trailing_zeros
  assign alt_per_day_display = alt_per_day_cents | money
  assign savings_display = savings_cents | money_without_trailing_zeros

  assign headline_html = section.settings.headline | replace: '[price]', stack_price_display | replace: '[savings]', savings_display | replace: '[pct]', savings_pct
  assign aside_html = section.settings.aside_text | replace: '[price]', stack_price_display | replace: '[savings]', savings_display | replace: '[pct]', savings_pct
  assign footer_right_html = section.settings.footer_right | replace: '[savings]', savings_display | replace: '[pct]', savings_pct
  assign save_tag_html = section.settings.save_tag | replace: '[savings]', savings_display | replace: '[pct]', savings_pct
  assign discount_label_html = section.settings.discount_label | replace: '[pct]', tier_pct
-%}

{%- style -%}
  .reken-{{ section.id }} {
    --rk-shell: {{ section.settings.bg_color }};
    --rk-ink: {{ section.settings.text_color }};
    --rk-ink-2: {{ section.settings.text_muted }};
    --rk-ink-3: {{ section.settings.text_faint }};
    --rk-hero-bg: {{ section.settings.hero_bg }};
    --rk-hero-ink: {{ section.settings.hero_text }};
    --rk-hero-ink-2: {{ section.settings.hero_text_muted }};
    --rk-alt-bg: {{ section.settings.alt_bg }};
    --rk-alt-ink: {{ section.settings.alt_text }};
    --rk-line: {{ section.settings.alt_rule }};
    --rk-line-hero: {{ section.settings.hero_rule }};
    --rk-lime: {{ section.settings.accent_lime }};
    --rk-lime-deep: {{ section.settings.accent_lime_deep }};
    --rk-check-bg: {{ section.settings.check_bg }};
    --rk-check-ink: {{ section.settings.check_ink }};
    --rk-badge-hero-bg: {{ section.settings.badge_hero_bg }};
    --rk-badge-hero-ink: {{ section.settings.badge_hero_ink }};
    --rk-strike: {{ section.settings.strike_color }};
    --rk-cta-bg: {{ section.settings.cta_bg }};
    --rk-cta-ink: {{ section.settings.cta_text }};
    --rk-cta-circ-bg: {{ section.settings.cta_circ_bg }};
    --rk-cta-circ-ink: {{ section.settings.cta_circ_ink }};
    --rk-radius: {{ section.settings.corner_radius }}px;
    --rk-radius-sm: {{ section.settings.corner_radius_sm }}px;
    background: var(--rk-shell);
    color: var(--rk-ink);
    padding-top: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .reken-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="reken-section reken-{{ section.id }}">
  <div class="reken-inner page-width">

    {%- if section.settings.eyebrow != blank -%}
      <p class="reken-eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    <div class="reken-head">
      {%- if section.settings.headline != blank -%}
        <h2 class="reken-headline">
          {{ headline_html }}
          {%- if section.settings.headline_highlight != blank -%}
            <span class="reken-headline__pop">{{ section.settings.headline_highlight | replace: '[savings]', savings_display | replace: '[pct]', savings_pct }}</span>
          {%- endif -%}
        </h2>
      {%- endif -%}

      <div class="reken-head__aside">
        {%- if section.settings.aside_text != blank -%}
          <div class="reken-head__copy">{{ aside_html }}</div>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a class="reken-cta" href="{{ section.settings.cta_link | default: '#' }}">
            {{ section.settings.cta_label | escape }}
            <span class="reken-cta__circ" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h9M8.5 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        {%- endif -%}
      </div>
    </div>

    <section class="reken-grid">

      <article class="reken-card reken-card--hero" aria-label="{{ section.settings.stack_heading | escape }}">
        {%- if section.settings.stack_badge != blank -%}
          <span class="reken-badge reken-badge--hero"><span class="reken-badge__dot"></span>{{ section.settings.stack_badge | escape }}</span>
        {%- endif -%}

        <header class="reken-card__head">
          <h3 class="reken-card__title">{{ section.settings.stack_heading | escape }}</h3>
          {%- if section.settings.stack_meta != blank -%}
            <span class="reken-card__sub">{{ section.settings.stack_meta | escape }}</span>
          {%- endif -%}
        </header>

        <div class="reken-rows">
          {%- for block in section.blocks -%}
            {%- if block.type == 'stack_item' -%}
              <div class="reken-row" {{ block.shopify_attributes }}>
                <div class="reken-row__label">
                  <span class="reken-mark reken-mark--check" aria-hidden="true">
                    <svg viewBox="0 0 12 12" fill="none"><path d="M2 6.5l2.5 2.5L10 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                  <span class="reken-row__name">{{ block.settings.label | escape }}</span>
                  {%- if block.settings.note != blank -%}
                    <span class="reken-row__meta">{{ block.settings.note | escape }}</span>
                  {%- endif -%}
                </div>
                <span class="reken-row__incl">{{ block.settings.value | default: section.settings.stack_value_label | escape }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="reken-total">
          {%- if section.settings.stack_total_label != blank -%}
            <span class="reken-total__label">{{ section.settings.stack_total_label | escape }}</span>
          {%- endif -%}
          <span class="reken-total__price">
            {%- if section.settings.show_was and stack_was_cents > stack_total_cents -%}
              <span class="reken-total__was">{{ stack_was_display }}</span>
            {%- endif -%}
            {{ stack_price_display }}
            {%- if stack_per_day_cents > 0 -%}
              <span class="reken-total__perday">
                {{ stack_per_day_display }} {{ section.settings.per_day_suffix | escape }}
                {%- if section.settings.show_discount_label and tier_pct > 0 -%}
                  · {{ discount_label_html }}
                {%- endif -%}
              </span>
            {%- endif -%}
          </span>
        </div>

        {%- assign stack_feature_count = 0 -%}
        {%- for b in section.blocks -%}
          {%- if b.type == 'stack_feature' -%}{%- assign stack_feature_count = stack_feature_count | plus: 1 -%}{%- endif -%}
        {%- endfor -%}
        {%- if stack_feature_count > 0 -%}
          <div class="reken-notes">
            {%- for block in section.blocks -%}
              {%- if block.type == 'stack_feature' -%}
                <div class="reken-note" {{ block.shopify_attributes }}>
                  <span class="reken-note__ico" aria-hidden="true">
                    {%- render 'reken-note-icon', icon: block.settings.icon_preset, image: block.settings.icon -%}
                  </span>
                  {{ block.settings.label | escape }}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </article>

      <article class="reken-card reken-card--alt" aria-label="{{ section.settings.alt_heading | escape }}">
        {%- if section.settings.alt_badge != blank -%}
          <span class="reken-badge reken-badge--alt"><span class="reken-badge__dot"></span>{{ section.settings.alt_badge | escape }}</span>
        {%- endif -%}

        <header class="reken-card__head">
          <h3 class="reken-card__title">{{ section.settings.alt_heading | escape }}</h3>
          {%- if section.settings.alt_meta != blank -%}
            <span class="reken-card__sub">{{ section.settings.alt_meta | escape }}</span>
          {%- endif -%}
        </header>

        <div class="reken-rows">
          {%- for block in section.blocks -%}
            {%- if block.type == 'alt_item' -%}
              <div class="reken-row" {{ block.shopify_attributes }}>
                <div class="reken-row__label">
                  <span class="reken-mark reken-mark--dot" aria-hidden="true"></span>
                  <span class="reken-row__name">{{ block.settings.label | escape }}</span>
                  {%- if block.settings.note != blank -%}
                    <span class="reken-row__meta">{{ block.settings.note | escape }}</span>
                  {%- endif -%}
                </div>
                <span class="reken-row__price">{{ block.settings.price | times: 100 | money_without_trailing_zeros }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="reken-total">
          {%- if section.settings.alt_total_label != blank -%}
            <span class="reken-total__label">{{ section.settings.alt_total_label | escape }}</span>
          {%- endif -%}
          <span class="reken-total__price">
            {{ alt_price_display }}
            {%- if alt_per_day_cents > 0 -%}
              <span class="reken-total__perday">{{ alt_per_day_display }} {{ section.settings.per_day_suffix | escape }}</span>
            {%- endif -%}
          </span>
        </div>

        {%- assign alt_feature_count = 0 -%}
        {%- for b in section.blocks -%}
          {%- if b.type == 'alt_feature' -%}{%- assign alt_feature_count = alt_feature_count | plus: 1 -%}{%- endif -%}
        {%- endfor -%}
        {%- if alt_feature_count > 0 -%}
          <div class="reken-notes">
            {%- for block in section.blocks -%}
              {%- if block.type == 'alt_feature' -%}
                <div class="reken-note" {{ block.shopify_attributes }}>
                  <span class="reken-note__ico" aria-hidden="true">
                    {%- render 'reken-note-icon', icon: block.settings.icon_preset, image: block.settings.icon -%}
                  </span>
                  {{ block.settings.label | escape }}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </article>

    </section>

    {%- if section.settings.footer_left != blank or section.settings.save_tag != blank or section.settings.footer_right != blank -%}
      <div class="reken-foot">
        {%- if section.settings.footer_left != blank -%}
          <span class="reken-foot__left">{{ section.settings.footer_left }}</span>
        {%- endif -%}
        {%- if section.settings.save_tag != blank -%}
          <span class="reken-foot__save">
            {%- if section.settings.save_prefix != blank -%}{{ section.settings.save_prefix | escape }}{%- endif -%}
            <span class="reken-foot__tag">{{ save_tag_html }}</span>
          </span>
        {%- elsif section.settings.footer_right != blank -%}
          <span class="reken-foot__right">{{ footer_right_html }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
  .reken-section { box-sizing: border-box; }
  .reken-inner {
    display: flex;
    flex-direction: column;
  }
  .reken-eyebrow {
    margin: 0 0 1.8rem;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--rk-ink-3);
  }
  .reken-head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2.4rem;
    margin-bottom: 4rem;
  }
  @media screen and (min-width: 860px) {
    .reken-head {
      flex-direction: row;
      align-items: flex-end;
      gap: 4rem;
    }
  }
  .reken-headline {
    margin: 0;
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: clamp(3.8rem, 5vw, 6.6rem);
    line-height: 0.98;
    letter-spacing: -0.01em;
    max-width: 100%;
  }
  @media screen and (min-width: 860px) {
    .reken-headline { max-width: 9ch; }
  }
  .reken-headline p { margin: 0; display: inline; }
  .reken-headline__pop {
    color: var(--rk-lime-deep);
  }
  .reken-head__aside {
    max-width: 33rem;
    padding-bottom: 0.8rem;
  }
  .reken-head__copy {
    font-size: 1.6rem;
    line-height: 1.5;
    color: var(--rk-ink-2);
    margin: 0 0 1.8rem;
  }
  .reken-head__copy p { margin: 0 0 1rem; }
  .reken-head__copy p:last-child { margin: 0; }
  .reken-cta {
    display: inline-flex;
    align-items: center;
    gap: 1.2rem;
    background: var(--rk-cta-bg);
    color: var(--rk-cta-ink);
    border: none;
    font-size: 1.5rem;
    font-weight: 600;
    padding: 1rem 1rem 1rem 2.2rem;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 200ms ease;
  }
  .reken-cta:hover { transform: translateY(-1px); }
  .reken-cta__circ {
    width: 3.4rem;
    height: 3.4rem;
    border-radius: 999px;
    background: var(--rk-cta-circ-bg);
    color: var(--rk-cta-circ-ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .reken-cta__circ svg { width: 1.5rem; height: 1.5rem; }

  .reken-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.8rem;
    align-items: stretch;
  }
  @media screen and (min-width: 860px) {
    .reken-grid {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }

  .reken-card {
    position: relative;
    border-radius: var(--rk-radius);
    padding: 3.4rem 3.4rem 3rem;
    display: flex;
    flex-direction: column;
    min-height: 54rem;
  }
  @media (max-width: 859px) {
    .reken-card { min-height: 0; padding: 2.8rem 2.4rem 2.4rem; }
    .reken-card--alt { order: -1; }
  }
  .reken-card--hero {
    background: var(--rk-hero-bg);
    color: var(--rk-hero-ink);
  }
  .reken-card--alt {
    background: var(--rk-alt-bg);
    color: var(--rk-alt-ink);
    border: 1px solid var(--rk-line);
  }

  .reken-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    align-self: flex-start;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 0.8rem 1.4rem;
    border-radius: 999px;
    margin-bottom: 2.6rem;
    white-space: nowrap;
  }
  .reken-badge--hero {
    background: var(--rk-badge-hero-bg);
    color: var(--rk-badge-hero-ink);
  }
  .reken-badge--alt {
    background: var(--rk-shell);
    color: var(--rk-ink-2);
  }
  .reken-badge__dot {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 999px;
    background: currentColor;
  }
  .reken-badge--hero .reken-badge__dot { background: var(--rk-lime); }

  .reken-card__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.6rem;
    margin-bottom: 2.2rem;
    flex-wrap: wrap;
  }
  .reken-card__title {
    margin: 0;
    font-family: var(--font-heading-family);
    font-weight: 600;
    font-size: 3rem;
    line-height: 1;
    letter-spacing: -0.005em;
  }
  .reken-card__sub {
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--rk-ink-3);
  }
  .reken-card--hero .reken-card__sub { color: var(--rk-hero-ink-2); }

  .reken-rows {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .reken-row {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 1.6rem;
    padding: 1.7rem 0;
    border-top: 1px solid var(--rk-line);
  }
  .reken-card--hero .reken-row { border-top-color: var(--rk-line-hero); }
  .reken-row:first-child { border-top: 0; padding-top: 0.4rem; }

  .reken-row__label {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 1.6rem;
    line-height: 1.25;
    font-weight: 600;
    flex-wrap: nowrap;
    min-width: 0;
  }
  .reken-row__name {
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .reken-row__meta {
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--rk-ink-3);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .reken-card--hero .reken-row__meta { color: var(--rk-hero-ink-2); }
  .reken-row__price {
    font-size: 1.6rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .reken-row__incl {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--rk-check-bg);
    background: color-mix(in srgb, var(--rk-lime) 60%, transparent);
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .reken-mark {
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .reken-mark--check {
    background: var(--rk-check-bg);
    color: var(--rk-check-ink);
  }
  .reken-mark--check svg { width: 1.2rem; height: 1.2rem; }
  .reken-mark--dot {
    background: transparent;
    border: 1.5px solid var(--rk-ink-3);
  }

  .reken-total {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.6rem;
    margin-top: 0.6rem;
    padding-top: 2.2rem;
    border-top: 1.5px solid var(--rk-line);
  }
  .reken-card--hero .reken-total { border-top-color: var(--rk-line-hero); }
  .reken-total__label {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--rk-ink-2);
    max-width: 12ch;
    line-height: 1.25;
  }
  .reken-card--hero .reken-total__label { color: var(--rk-hero-ink-2); }
  .reken-total__price {
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: 3.9rem;
    line-height: 0.9;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  .reken-total__was {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--rk-ink-3);
    text-decoration: line-through;
    text-decoration-thickness: 2px;
    text-decoration-color: var(--rk-strike);
    margin-right: 1rem;
    vertical-align: 0.2rem;
  }
  .reken-total__perday {
    display: block;
    font-family: var(--font-body-family);
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--rk-ink-3);
    margin-top: 0.8rem;
  }
  .reken-card--hero .reken-total__perday { color: var(--rk-hero-ink-2); }

  .reken-notes {
    margin-top: 2.2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .reken-note {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--rk-ink-2);
    line-height: 1.3;
  }
  .reken-card--hero .reken-note { color: var(--rk-hero-ink-2); }
  .reken-note__ico {
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .reken-card--hero .reken-note__ico { background: rgba(255, 255, 255, 0.45); }
  .reken-card--alt .reken-note__ico { background: var(--rk-shell); }
  .reken-note__ico svg { width: 1.6rem; height: 1.6rem; stroke-width: 1.7; }
  .reken-note__ico img {
    width: 1.6rem;
    height: 1.6rem;
    object-fit: contain;
  }

  .reken-foot {
    margin-top: 1.8rem;
    background: var(--rk-alt-bg);
    border: 1px solid var(--rk-line);
    border-radius: var(--rk-radius-sm);
    padding: 1.8rem 2.6rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.4rem;
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--rk-ink-3);
    flex-wrap: wrap;
  }
  .reken-foot__left p,
  .reken-foot__right p { margin: 0; display: inline; }
  .reken-foot__save {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    color: var(--rk-ink);
    font-weight: 700;
    font-size: 1.4rem;
  }
  .reken-foot__tag {
    background: var(--rk-lime);
    color: var(--rk-ink);
    padding: 0.5rem 1.2rem;
    border-radius: 999px;
    font-variant-numeric: tabular-nums;
  }
  @media (max-width: 560px) {
    .reken-foot { flex-direction: column; align-items: flex-start; gap: 1.4rem; }
  }

  @media (max-width: 859px) {
    .reken-row { padding: 1.3rem 0; gap: 1rem; }
    .reken-row__label { font-size: 1.35rem; gap: 1rem; }
    .reken-row__meta { font-size: 1.1rem; }
    .reken-row__price { font-size: 1.4rem; }
    .reken-row__incl { font-size: 1.1rem; padding: 0.4rem 0.9rem; }
    .reken-mark { width: 2rem; height: 2rem; }
    .reken-mark--check svg { width: 1.1rem; height: 1.1rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .reken-cta { transition: none; }
  }
{% endstylesheet %}

