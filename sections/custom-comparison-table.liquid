{%- liquid
  assign chosen_product = section.settings.product
  if chosen_product == blank and template.name == 'product'
    assign chosen_product = product
  endif
  assign product = chosen_product
  assign tier_qty = section.settings.tier_qty | default: 1
  assign tier_pct = section.settings.tier_pct | default: 16
  assign sticks_per_pack = section.settings.sticks_per_pack | default: 30

  assign price_source = section.settings.price_source
  assign stack_total_cents = 0
  if price_source == 'product' and product != blank
    assign base_variant_price = product.selected_or_first_available_variant.price
    assign stack_total_cents = base_variant_price | times: tier_qty
    assign discount_factor = 100 | minus: tier_pct
    assign stack_total_cents = stack_total_cents | times: discount_factor | divided_by: 100
  else
    assign stack_total_cents = section.settings.stack_total_manual | times: 100
  endif

  assign total_sticks = tier_qty | times: sticks_per_pack
  assign stack_per_day_cents = 0
  if total_sticks > 0
    assign stack_per_day_cents = stack_total_cents | divided_by: total_sticks | round
  endif

  assign alt_total_cents = 0
  for block in section.blocks
    if block.type == 'alt_item'
      assign item_price_cents = block.settings.price | times: 100
      assign alt_total_cents = alt_total_cents | plus: item_price_cents
    endif
  endfor

  assign alt_per_day_cents = 0
  if total_sticks > 0 and alt_total_cents > 0
    assign alt_per_day_cents = alt_total_cents | divided_by: total_sticks | round
  endif

  assign savings_cents = alt_total_cents | minus: stack_total_cents
  assign savings_pct = 0
  if alt_total_cents > 0 and savings_cents > 0
    assign savings_pct = savings_cents | times: 100 | divided_by: alt_total_cents | round
  endif

  assign stack_price_display = stack_total_cents | money_without_trailing_zeros
  assign stack_per_day_display = stack_per_day_cents | money
  assign alt_price_display = alt_total_cents | money_without_trailing_zeros
  assign alt_per_day_display = alt_per_day_cents | money
  assign savings_display = savings_cents | money_without_trailing_zeros

  assign title_html = section.settings.title | replace: '[price]', stack_price_display
  assign footer_right_html = section.settings.footer_right | replace: '[savings]', savings_display | replace: '[pct]', savings_pct
-%}

{%- style -%}
  .compare-{{ section.id }} {
    --cmp-bg: {{ section.settings.bg_color }};
    --cmp-text: {{ section.settings.text_color }};
    --cmp-stack-bg: {{ section.settings.stack_bg }};
    --cmp-stack-text: {{ section.settings.stack_text }};
    --cmp-stack-rule: {{ section.settings.stack_rule }};
    --cmp-stack-check: {{ section.settings.stack_check }};
    --cmp-alt-bg: {{ section.settings.alt_bg }};
    --cmp-alt-text: {{ section.settings.alt_text }};
    --cmp-alt-rule: {{ section.settings.alt_rule }};
    --cmp-alt-muted: {{ section.settings.alt_muted }};
    --cmp-cta-bg: {{ section.settings.cta_bg }};
    --cmp-cta-text: {{ section.settings.cta_text }};
    --cmp-radius: {{ section.settings.corner_radius }}px;
    padding-top: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
    background: var(--cmp-bg);
    color: var(--cmp-text);
  }
  @media screen and (min-width: 750px) {
    .compare-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="compare-section compare-{{ section.id }}">
  <div class="compare-inner page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="compare-title">{{ title_html }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="compare-subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    <div class="compare-grid">
      <article class="compare-card compare-card--stack">
        {%- if section.settings.stack_badge != blank -%}
          <span class="compare-badge compare-badge--stack">{{ section.settings.stack_badge | escape }}</span>
        {%- endif -%}

        <header class="compare-card__head">
          <h3 class="compare-card__title">{{ section.settings.stack_heading | escape }}</h3>
          {%- if section.settings.stack_meta != blank -%}
            <span class="compare-card__meta">{{ section.settings.stack_meta | escape }}</span>
          {%- endif -%}
        </header>

        <ul class="compare-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'stack_item' -%}
              <li class="compare-row" {{ block.shopify_attributes }}>
                <span class="compare-row__icon compare-row__icon--check" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                </span>
                <span class="compare-row__label">
                  {{ block.settings.label | escape }}
                  {%- if block.settings.note != blank -%}
                    <span class="compare-row__note">{{ block.settings.note | escape }}</span>
                  {%- endif -%}
                </span>
                <span class="compare-row__value">{{ block.settings.value | default: section.settings.stack_value_label | escape }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>

        <div class="compare-card__price">
          <div class="compare-card__price-meta">
            <span class="compare-card__price-label">{{ section.settings.stack_total_label | escape }}</span>
          </div>
          <div class="compare-card__price-amount">
            <span class="compare-card__price-value">{{ stack_price_display }}</span>
            {%- if stack_per_day_cents > 0 -%}
              <span class="compare-card__price-perday">{{ stack_per_day_display }} {{ section.settings.per_day_suffix | escape }}</span>
            {%- endif -%}
          </div>
        </div>

        {%- assign stack_feature_count = 0 -%}
        {%- for b in section.blocks -%}
          {%- if b.type == 'stack_feature' -%}{%- assign stack_feature_count = stack_feature_count | plus: 1 -%}{%- endif -%}
        {%- endfor -%}

        {%- if stack_feature_count > 0 or section.settings.cta_label != blank -%}
          <div class="compare-card__foot">
            {%- if stack_feature_count > 0 -%}
              <ul class="compare-features">
                {%- for block in section.blocks -%}
                  {%- if block.type == 'stack_feature' -%}
                    <li class="compare-feature" {{ block.shopify_attributes }}>
                      <span class="compare-feature__icon" aria-hidden="true">
                        {%- if block.settings.icon != blank -%}
                          {{ block.settings.icon | image_url: width: 48 | image_tag: width: 24, height: 24, alt: '', loading: 'lazy' }}
                        {%- else -%}
                          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/></svg>
                        {%- endif -%}
                      </span>
                      <span class="compare-feature__text">{{ block.settings.label | escape }}</span>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}

            {%- if section.settings.cta_label != blank -%}
              <a
                href="{{ section.settings.cta_link | default: '#' }}"
                class="compare-cta"
              >
                {{ section.settings.cta_label | escape }}
                <span aria-hidden="true">&nbsp;→</span>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </article>

      <div class="compare-vs" aria-hidden="true">
        <span>{{ section.settings.vs_label | default: 'vs' | escape }}</span>
      </div>

      <article class="compare-card compare-card--alt">
        {%- if section.settings.alt_badge != blank -%}
          <span class="compare-badge compare-badge--alt">{{ section.settings.alt_badge | escape }}</span>
        {%- endif -%}

        <header class="compare-card__head">
          <h3 class="compare-card__title">{{ section.settings.alt_heading | escape }}</h3>
          {%- if section.settings.alt_meta != blank -%}
            <span class="compare-card__meta">{{ section.settings.alt_meta | escape }}</span>
          {%- endif -%}
        </header>

        <ul class="compare-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'alt_item' -%}
              <li class="compare-row" {{ block.shopify_attributes }}>
                <span class="compare-row__icon compare-row__icon--ring" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/></svg>
                </span>
                <span class="compare-row__label">
                  {{ block.settings.label | escape }}
                  {%- if block.settings.note != blank -%}
                    <span class="compare-row__note">{{ block.settings.note | escape }}</span>
                  {%- endif -%}
                </span>
                <span class="compare-row__value">{{ block.settings.price | times: 100 | money_without_trailing_zeros }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>

        <div class="compare-card__price">
          <div class="compare-card__price-amount compare-card__price-amount--strike">
            <span class="compare-card__price-value">{{ alt_price_display }}</span>
            {%- if alt_per_day_cents > 0 -%}
              <span class="compare-card__price-perday">{{ alt_per_day_display }} {{ section.settings.per_day_suffix | escape }}</span>
            {%- endif -%}
          </div>
          <div class="compare-card__price-meta">
            <span class="compare-card__price-label">{{ section.settings.alt_total_label | escape }}</span>
          </div>
        </div>

        {%- assign alt_feature_count = 0 -%}
        {%- for b in section.blocks -%}
          {%- if b.type == 'alt_feature' -%}{%- assign alt_feature_count = alt_feature_count | plus: 1 -%}{%- endif -%}
        {%- endfor -%}

        {%- if alt_feature_count > 0 -%}
          <div class="compare-card__foot">
            <ul class="compare-features">
              {%- for block in section.blocks -%}
                {%- if block.type == 'alt_feature' -%}
                  <li class="compare-feature" {{ block.shopify_attributes }}>
                    <span class="compare-feature__icon" aria-hidden="true">
                      {%- if block.settings.icon != blank -%}
                        {{ block.settings.icon | image_url: width: 48 | image_tag: width: 24, height: 24, alt: '', loading: 'lazy' }}
                      {%- else -%}
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/></svg>
                      {%- endif -%}
                    </span>
                    <span class="compare-feature__text">{{ block.settings.label | escape }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </article>
    </div>

    {%- if section.settings.footer_left != blank or section.settings.footer_right != blank -%}
      <div class="compare-footer">
        {%- if section.settings.footer_left != blank -%}
          <span class="compare-footer__left">{{ section.settings.footer_left }}</span>
        {%- endif -%}
        {%- if section.settings.footer_right != blank -%}
          <span class="compare-footer__right">{{ footer_right_html }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .compare-section { box-sizing: border-box; }
  .compare-inner {
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
  }
  .compare-title {
    margin: 0;
    font-size: clamp(3.2rem, 5.5vw, 6.4rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    font-weight: 700;
    max-width: 24ch;
  }
  .compare-subtitle {
    margin: 0;
    font-size: clamp(1.5rem, 1.6vw, 1.8rem);
    line-height: 1.45;
    max-width: 60ch;
    opacity: 0.85;
  }
  .compare-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    position: relative;
  }
  @media screen and (min-width: 990px) {
    .compare-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.4rem;
    }
  }
  .compare-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 2.4rem;
    border-radius: var(--cmp-radius, 24px);
    min-width: 0;
  }
  @media screen and (min-width: 750px) {
    .compare-card { padding: 3.2rem; }
  }
  .compare-card--stack {
    background: var(--cmp-stack-bg);
    color: var(--cmp-stack-text);
  }
  .compare-card--alt {
    background: var(--cmp-alt-bg);
    color: var(--cmp-alt-text);
  }
  .compare-badge {
    position: absolute;
    top: -1.2rem;
    left: 2rem;
    padding: 0.5rem 1.2rem;
    border-radius: 999px;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: var(--cmp-stack-bg);
    color: var(--cmp-stack-text);
    border: 1px solid currentColor;
  }
  .compare-badge--alt {
    background: var(--cmp-alt-bg);
    color: var(--cmp-alt-text);
    border: 1px solid var(--cmp-alt-muted);
  }
  .compare-card__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem 1.6rem;
  }
  .compare-card__title {
    margin: 0;
    font-size: clamp(2.4rem, 2.4vw, 3.2rem);
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .compare-card__meta {
    font-size: 1.4rem;
    opacity: 0.7;
  }
  .compare-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .compare-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.2rem;
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--cmp-stack-rule);
  }
  .compare-card--alt .compare-row {
    border-bottom-color: var(--cmp-alt-rule);
  }
  .compare-row:last-child { border-bottom: 0; }
  .compare-row__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    flex: 0 0 auto;
  }
  .compare-row__icon--check { color: var(--cmp-stack-check); }
  .compare-row__icon--ring { color: var(--cmp-alt-muted); }
  .compare-row__label {
    font-size: 1.6rem;
    line-height: 1.3;
    display: inline-flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4rem 0.8rem;
  }
  .compare-row__note {
    font-size: 1.3rem;
    opacity: 0.65;
  }
  .compare-row__value {
    font-size: 1.5rem;
    text-align: right;
    opacity: 0.7;
    white-space: nowrap;
  }
  .compare-card__price {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.2rem 2rem;
    margin-top: 0.8rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--cmp-stack-rule);
  }
  .compare-card--alt .compare-card__price {
    border-top-color: var(--cmp-alt-rule);
  }
  .compare-card__price-label {
    font-size: 1.8rem;
    font-weight: 600;
  }
  .compare-card__price-amount {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    line-height: 1;
  }
  .compare-card__price-value {
    font-family: var(--font-heading-family);
    font-style: italic;
    font-size: clamp(3.6rem, 4.4vw, 5.6rem);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .compare-card__price-amount--strike .compare-card__price-value {
    text-decoration: line-through;
    text-decoration-thickness: 1.5px;
    opacity: 0.55;
  }
  .compare-card__price-perday {
    margin-top: 0.6rem;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .compare-card__foot {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    margin-top: auto;
  }
  .compare-features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .compare-feature {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 1.4rem;
    opacity: 0.9;
  }
  .compare-feature__icon {
    display: inline-flex;
    width: 2rem;
    height: 2rem;
    align-items: center;
    justify-content: center;
  }
  .compare-feature__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .compare-cta {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1.4rem 2.4rem;
    border-radius: 999px;
    background: var(--cmp-cta-bg);
    color: var(--cmp-cta-text);
    font-family: var(--font-heading-family);
    font-style: italic;
    font-size: 1.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 200ms ease, opacity 200ms ease;
    min-height: 4.4rem;
  }
  .compare-cta:hover { transform: translateY(-1px); }
  .compare-cta:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }
  .compare-vs {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 4.4rem;
    height: 4.4rem;
    border-radius: 50%;
    background: var(--cmp-bg);
    color: var(--cmp-text);
    border: 1px solid currentColor;
    display: none;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    font-style: italic;
    font-weight: 500;
    z-index: 1;
  }
  @media screen and (min-width: 990px) {
    .compare-vs { display: flex; }
  }
  .compare-footer {
    display: flex;
    justify-content: space-between;
    gap: 1.6rem;
    flex-wrap: wrap;
    font-size: 1.3rem;
    opacity: 0.65;
  }
  @media (prefers-reduced-motion: reduce) {
    .compare-cta { transition: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Pack comparison",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "info": "Use [price] to insert the Daily Matter total price.",
      "default": "<p>Waar je [price] voor betaalt.</p>"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>Eén sachet per dag. Geen drie potten, geen schepjes, geen ochtend-checklist.</p>"
    },
    {
      "type": "header",
      "content": "Stack (left) card"
    },
    {
      "type": "text",
      "id": "stack_badge",
      "label": "Badge",
      "default": "JOUW STACK"
    },
    {
      "type": "text",
      "id": "stack_heading",
      "label": "Card heading",
      "default": "Daily Matter"
    },
    {
      "type": "text",
      "id": "stack_meta",
      "label": "Card meta",
      "default": "1 sachet · per dag"
    },
    {
      "type": "text",
      "id": "stack_value_label",
      "label": "Default item value label",
      "info": "Used when a stack item leaves the value field blank.",
      "default": "inbegrepen"
    },
    {
      "type": "text",
      "id": "stack_total_label",
      "label": "Total label",
      "default": "30 sachets — één maand"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Start vandaag"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Alternative (right) card"
    },
    {
      "type": "text",
      "id": "alt_badge",
      "label": "Badge",
      "default": "HET ALTERNATIEF"
    },
    {
      "type": "text",
      "id": "alt_heading",
      "label": "Card heading",
      "default": "Los samenstellen"
    },
    {
      "type": "text",
      "id": "alt_meta",
      "label": "Card meta",
      "default": "3 potten · 3 routines"
    },
    {
      "type": "text",
      "id": "alt_total_label",
      "label": "Total label",
      "default": "Totaal per maand"
    },
    {
      "type": "header",
      "content": "Pricing"
    },
    {
      "type": "select",
      "id": "price_source",
      "label": "Stack price source",
      "options": [
        { "value": "product", "label": "Derive from product (lowest subscription tier)" },
        { "value": "manual", "label": "Manual" }
      ],
      "default": "product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Daily Matter price = first variant × tier qty × (1 − tier %). Defaults to the current product on PDPs if blank."
    },
    {
      "type": "range",
      "id": "tier_qty",
      "label": "Lowest tier quantity",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "tier_pct",
      "label": "Lowest tier discount %",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "%",
      "default": 16
    },
    {
      "type": "range",
      "id": "stack_total_manual",
      "label": "Manual stack total",
      "info": "Used only when stack price source is set to Manual.",
      "min": 0,
      "max": 500,
      "step": 1,
      "unit": "€",
      "default": 47
    },
    {
      "type": "range",
      "id": "sticks_per_pack",
      "label": "Sachets per pack",
      "min": 1,
      "max": 120,
      "step": 1,
      "default": 30
    },
    {
      "type": "text",
      "id": "per_day_suffix",
      "label": "Per-day suffix",
      "default": "per dag"
    },
    {
      "type": "text",
      "id": "vs_label",
      "label": "VS label",
      "default": "vs"
    },
    {
      "type": "header",
      "content": "Footer"
    },
    {
      "type": "richtext",
      "id": "footer_left",
      "label": "Footer left",
      "default": "<p>Prijzen op basis van gemiddelde retail per stuk.</p>"
