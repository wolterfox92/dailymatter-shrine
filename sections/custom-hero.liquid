  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Energie · Focus · Hydratatie"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<p>Your daily foundation for better energy.</p>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body text",
      "default": "<p>Eenvoudige dagelijkse supplementen voor energie, focus en hydratatie. Eén sachet, gemengd met water — gemaakt om in je routine te passen.</p>"
    },
    {
      "type": "header",
      "content": "Buttons"
