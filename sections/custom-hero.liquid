    },
    {
      "type": "text",
      "id": "rating_reviews",
      "label": "Reviews",
      "default": "1.284 reviews"
    },
    {
      "type": "text",
      "id": "rating_extra",
      "label": "Extra label",
      "default": "100% vegan"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_ratio",
      "label": "Image ratio (e.g. 4 / 5)",
