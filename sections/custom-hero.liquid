    },
    {
      "type": "checkbox",
      "id": "show_media_rating",
      "label": "Show rating badge on image",
      "default": true
    },
    {
      "type": "text",
      "id": "media_rating_score",
      "label": "Image rating score",
      "default": "4,7/5"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#2E2A39"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#6B6776"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#CBFF78"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Stars",
      "default": "#9FE05A"
    },
    {
      "type": "header",
      "content": "Eyebrow colors"
    },
    {
      "type": "color",
      "id": "eyebrow_bg",
      "label": "Eyebrow background",
      "default": "#F1F0EE"
    },
    {
      "type": "color",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "#2E2A39"
    },
    {
      "type": "header",
      "content": "Primary button colors"
    },
    {
      "type": "color",
      "id": "primary_bg",
      "label": "Primary background",
      "default": "#CBFF78"
    },
    {
      "type": "color",
      "id": "primary_text",
      "label": "Primary text",
      "default": "#2E2A39"
    },
    {
      "type": "header",
      "content": "Secondary button colors"
