{%- liquid
  assign is_rtl = false
  if settings.enable_rtl == true
    assign is_rtl = true
  elsif settings.rtl_enabled_languages != blank
    assign lang_array_trim = settings.rtl_enabled_languages | replace: ' ', '' | split: ','
    if lang_array_trim contains localization.language.iso_code
      assign is_rtl = true
    endif
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }

  .selling-points-ticker-{{ section.id }} {
    --sp-text-color: {{ section.settings.text_color }};
    --sp-icon-color: {{ section.settings.icon_color }};
    --sp-icon-gap: {{ section.settings.icon_gap | divided_by: 10.0 }}rem;
    --sp-text-size: {{ section.settings.mobile_text_size | divided_by: 10.0 }}rem;
    --sp-icon-size: {{ section.settings.mobile_icon_size | divided_by: 10.0 }}rem;
    background-color: {{ section.settings.background_color }};
    overflow: hidden;
  }

  .selling-points-ticker-{{ section.id }} .selling-points-ticker__container {
    display: flex;
    align-items: center;
    width: max-content;
    column-gap: var(--sp-icon-gap);
    animation: sellingPointsTicker{{ section.id }} {{ 150 | divided_by: section.settings.speed }}s linear infinite {{ section.settings.direction }} forwards;
  }

  {% if section.settings.stop_on_hover %}
    .selling-points-ticker-{{ section.id }}:hover .selling-points-ticker__container {
      animation-play-state: paused;
    }
  {% endif %}

  .selling-points-ticker-{{ section.id }} .selling-points-ticker__item {
    display: inline-flex;
    align-items: center;
    column-gap: var(--sp-icon-gap);
    flex-shrink: 0;
  }

  .selling-points-ticker-{{ section.id }} .selling-points-ticker__text {
    color: var(--sp-text-color);
    font-size: var(--sp-text-size);
    line-height: 1;
    letter-spacing: -0.01em;
    white-space: nowrap;
    margin: 0;
  }

  {% if section.settings.bold_text %}
    .selling-points-ticker-{{ section.id }} .selling-points-ticker__text { font-weight: 700; }
  {% endif %}
  {% if section.settings.uppercase_text %}
    .selling-points-ticker-{{ section.id }} .selling-points-ticker__text { text-transform: uppercase; }
  {% endif %}
  {% if section.settings.italic_text %}
    .selling-points-ticker-{{ section.id }} .selling-points-ticker__text { font-style: italic; }
  {% endif %}

  .selling-points-ticker-{{ section.id }} .selling-points-ticker__icon .material-icon {
    font-size: var(--sp-icon-size);
    color: var(--sp-icon-color);
    display: block;
  }

  .selling-points-ticker-{{ section.id }} .selling-points-ticker__icon-img {
    height: var(--sp-icon-size);
    width: auto;
    display: block;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.desktop_padding_top }}px;
      padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
    }

    .selling-points-ticker-{{ section.id }} {
      --sp-text-size: {{ section.settings.desktop_text_size | divided_by: 10.0 }}rem;
      --sp-icon-size: {{ section.settings.desktop_icon_size | divided_by: 10.0 }}rem;
    }
  }

  @keyframes sellingPointsTicker{{ section.id }} {
    to {
      transform: translateX(calc({% unless is_rtl %}-{% endunless %}50% {% if is_rtl %}+{% else %}-{% endif %} var(--sp-icon-gap) / 2));
    }
  }
{%- endstyle -%}

{%- liquid
  assign unique_blocks_total = section.blocks | size
  if unique_blocks_total > 0
    assign target_multiply = 20 | divided_by: unique_blocks_total | floor
    if target_multiply < 1
      assign target_multiply = 1
    endif
    assign target_total = unique_blocks_total | times: target_multiply | times: 2
  else
    assign target_total = 0
  endif
-%}

<div
  class="selling-points-ticker selling-points-ticker-{{ section.id }} content-for-grouping section-{{ section.id }}-padding {{ section.settings.visibility }}"
>
  <div class="selling-points-ticker__container">
    {%- assign block_counter = 0 -%}

    {%- for block in section.blocks -%}
      {%- assign block_counter = block_counter | plus: 1 -%}
      <div class="selling-points-ticker__item" {{ block.shopify_attributes }}>
        {%- if block.settings.text != blank -%}
          <p class="selling-points-ticker__text">{{ block.settings.text }}</p>
        {%- endif -%}
        {%- if block.settings.custom_icon != blank -%}
          <img
            class="selling-points-ticker__icon-img"
            src="{{ block.settings.custom_icon | image_url: width: 200 }}"
            width="auto"
            height="auto"
            loading="lazy"
            alt="{{ block.settings.custom_icon.alt | escape }}"
          >
        {%- elsif block.settings.icon != blank -%}
          <span class="selling-points-ticker__icon">
            {%- render 'material-icon', icon: block.settings.icon, filled: block.settings.filled_icon -%}
          </span>
        {%- endif -%}
      </div>
    {%- endfor -%}

    {%- if block_counter < target_total -%}
      {%- for i in (1..15) -%}
        {%- for block in section.blocks -%}
          <div class="selling-points-ticker__item" aria-hidden="true">
            {%- if block.settings.text != blank -%}
              <p class="selling-points-ticker__text">{{ block.settings.text }}</p>
            {%- endif -%}
            {%- if block.settings.custom_icon != blank -%}
              <img
                class="selling-points-ticker__icon-img"
                src="{{ block.settings.custom_icon | image_url: width: 200 }}"
                width="auto"
                height="auto"
                loading="lazy"
                alt="{{ block.settings.custom_icon.alt | escape }}"
              >
            {%- elsif block.settings.icon != blank -%}
              <span class="selling-points-ticker__icon">
                {%- render 'material-icon', icon: block.settings.icon, filled: block.settings.filled_icon -%}
              </span>
            {%- endif -%}
          </div>

          {%- assign block_counter = block_counter | plus: 1 -%}
          {%- if block_counter >= target_total -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if block_counter >= target_total -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Selling points ticker",
  "class": "selling-points-ticker-section",
  "settings": [
    {
      "type": "select",
      "id": "visibility",
      "options": [
        {
          "value": "desktop-hidden",
          "label": "Mobile only"
        },
        {
          "value": "mobile-hidden",
          "label": "Desktop only"
        },
        {
          "value": "always-display",
          "label": "All devices"
        }
      ],
      "label": "Display on",
      "default": "always-display"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Speed",
      "min": 1,
      "max": 5,
      "default": 3,
      "step": 0.5
    },
    {
      "type": "select",
      "id": "direction",
      "options": [
        {
          "value": "normal",
          "label": "Right to left"
        },
        {
          "value": "reverse",
          "label": "Left to right"
        }
      ],
      "label": "Direction",
      "default": "normal"
    },
    {
      "type": "checkbox",
      "id": "stop_on_hover",
      "label": "Pause on hover/touch",
      "default": false
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "range",
      "id": "mobile_text_size",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 24,
      "label": "Mobile text size"
    },
    {
      "type": "range",
      "id": "desktop_text_size",
      "min": 16,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 40,
      "label": "Desktop text size"
    },
    {
      "type": "checkbox",
      "id": "bold_text",
      "label": "Bold text",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "italic_text",
      "label": "Italic text",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "uppercase_text",
      "label": "Uppercase text",
      "default": false
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "range",
      "id": "mobile_icon_size",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 22,
      "label": "Mobile icon size"
    },
    {
      "type": "range",
      "id": "desktop_icon_size",
      "min": 16,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 32,
      "label": "Desktop icon size"
    },
    {
      "type": "range",
      "id": "icon_gap",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 20,
      "label": "Space around icons",
      "info": "Space on each side of the icon, between it and the text on either side."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#25162f"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon",
      "default": "#25162f"
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top",
      "default": 12
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom",
      "default": 12
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "range",
      "id": "desktop_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top",
      "default": 16
    },
    {
      "type": "range",
      "id": "desktop_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "selling_point",
      "name": "Selling point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Shake"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon",
          "default": "bolt",
          "info": "[View all available icons](https:\/\/fonts.google.com\/icons?icon.set=Material+Symbols&icon.platform=web)."
        },
        {
          "type": "checkbox",
          "id": "filled_icon",
          "label": "Filled icon",
          "default": true
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom icon",
          "info": "Overrides the icon above. Use a transparent PNG/SVG."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Selling points ticker",
      "blocks": [
        {
          "type": "selling_point",
          "settings": {
            "text": "Shake",
            "icon": "local_bar"
          }
        },
        {
          "type": "selling_point",
          "settings": {
            "text": "Sip",
            "icon": "bolt"
          }
        },
        {
          "type": "selling_point",
          "settings": {
            "text": "Get Energized",
            "icon": "mood"
          }
        }
      ]
    }
  ]
}
{% endschema %}
