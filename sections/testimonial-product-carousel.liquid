{%- liquid
  assign heading           = section.settings.heading
  assign heading_size      = section.settings.heading_size
  assign subheading        = section.settings.subheading
  assign card_title_size   = section.settings.card_title_size
  assign card_text_size    = section.settings.card_text_size
  assign bg_color      = section.settings.bg_color
  assign text_color    = section.settings.text_color
  assign max_width     = section.settings.max_width
  assign pt            = section.settings.padding_top
  assign pb            = section.settings.padding_bottom
  assign cards_visible = section.settings.cards_per_view
  assign show_arrows   = section.settings.show_arrows
  assign show_dots     = section.settings.show_dots
  assign autoplay      = section.settings.autoplay
  assign autoplay_spd  = section.settings.autoplay_speed | times: 1000
  assign sid           = section.id
  assign gap           = 16
-%}

{%- style -%}
  #tpc-section-{{ sid }} {
    background-color: {{ bg_color }};
    padding-top: {{ pt | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ pb | times: 0.75 | round: 0 }}px;
    box-sizing: border-box;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    #tpc-section-{{ sid }} {
      padding-top: {{ pt }}px;
      padding-bottom: {{ pb }}px;
    }
  }

  #tpc-section-{{ sid }} .tpc-inner {
    max-width: {{ max_width }}px;
    margin-inline: auto;
    padding-inline: 20px;
    box-sizing: border-box;
  }

  #tpc-section-{{ sid }} .tpc-header {
    margin-bottom: 32px;
  }

  #tpc-section-{{ sid }} .tpc-heading {
    margin: 0 0 10px;
    color: {{ text_color }};
    /* font size/family/weight come from the heading size class applied in HTML */
  }

  #tpc-section-{{ sid }} .tpc-subheading {
    margin: 0;
    color: {{ text_color }};
    opacity: 0.72;
    max-width: 560px;
    /* font size/family/line-height come from .text-body applied in HTML */
  }

  /* ── Carousel wrapper ─────────────────────────────────────── */
  #tpc-section-{{ sid }} .tpc-carousel-outer {
    position: relative;
  }

  #tpc-section-{{ sid }} .tpc-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: {{ gap }}px;
    padding-bottom: 4px; /* prevent clipping shadows */
  }

  #tpc-section-{{ sid }} .tpc-track::-webkit-scrollbar {
    display: none;
  }

  /* ── Cards ────────────────────────────────────────────────── */
  #tpc-section-{{ sid }} .tpc-card {
    flex: 0 0 calc((100% + {{ gap }}px) / {{ cards_visible }} - {{ gap }}px);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    overflow: hidden;
    min-height: 380px;
    box-sizing: border-box;
  }

  @media screen and (max-width: 749px) {
    #tpc-section-{{ sid }} .tpc-card {
      /* Show roughly one card with a peek of the next */
      flex: 0 0 calc(88% - {{ gap }}px);
    }
  }

  #tpc-section-{{ sid }} .tpc-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 24px 24px 0;
  }

  #tpc-section-{{ sid }} .tpc-card__title {
    margin: 0 0 14px;
    color: inherit;  /* stay within card text color, not theme foreground */
    /* font size/family from .h4 applied in HTML */
  }

  #tpc-section-{{ sid }} .tpc-card__text {
    flex: 1;
    margin: 0 0 20px;
    opacity: 0.85;
    font-size: {{ card_text_size }};
    /* font-family/line-height from .text-body applied in HTML */
  }

  #tpc-section-{{ sid }} .tpc-card__customer {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-bottom: 20px;
  }

  #tpc-section-{{ sid }} .tpc-card__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  #tpc-section-{{ sid }} .tpc-card__customer-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  #tpc-section-{{ sid }} .tpc-card__name {
    font-size: 1.4rem;
    font-weight: 600;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  #tpc-section-{{ sid }} .tpc-card__label {
    font-size: 1.2rem;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
    opacity: 0.65;
  }

  /* ── Product bar ──────────────────────────────────────────── */
  #tpc-section-{{ sid }} .tpc-product-bar {
    margin: 0 12px 12px;
    padding: 10px 12px 10px 10px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 54px;
    flex-shrink: 0;
  }

  #tpc-section-{{ sid }} .tpc-product-bar__img-wrap {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
    background: rgba(255,255,255,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #tpc-section-{{ sid }} .tpc-product-bar__img {
    width: 36px;
    height: 36px;
    object-fit: cover;
    display: block;
  }

  #tpc-section-{{ sid }} .tpc-product-bar__name {
    flex: 1;
    font-size: 1.4rem;
    font-weight: 600;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  #tpc-section-{{ sid }} .tpc-atc-form {
    display: contents;
  }

  #tpc-section-{{ sid }} .tpc-atc-btn {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.18);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, transform 0.15s;
    padding: 0;
    color: inherit;
  }

  #tpc-section-{{ sid }} .tpc-atc-btn:hover:not(:disabled) {
    background: rgba(255,255,255,0.28);
    transform: scale(1.08);
  }

  #tpc-section-{{ sid }} .tpc-atc-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  #tpc-section-{{ sid }} .tpc-atc-btn svg {
    pointer-events: none;
  }

  /* Loading state — managed by the theme's product-form custom element */
  #tpc-section-{{ sid }} .tpc-atc-btn.loading .tpc-icon { display: none; }

  #tpc-section-{{ sid }} .tpc-atc-btn .loading-overlay__spinner {
    width: 18px;
    height: 18px;
  }

  #tpc-section-{{ sid }} .tpc-atc-btn .spinner {
    width: 18px;
    height: 18px;
  }

  /* ── Arrows ───────────────────────────────────────────────── */
  #tpc-section-{{ sid }} .tpc-arrows {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-top: 20px;
  }

  #tpc-section-{{ sid }} .tpc-arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid {{ text_color }};
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ text_color }};
    transition: background 0.2s, color 0.2s;
    flex-shrink: 0;
    padding: 0;
  }

  #tpc-section-{{ sid }} .tpc-arrow:hover:not(:disabled) {
    background: {{ text_color }};
    color: {{ bg_color }};
  }

  #tpc-section-{{ sid }} .tpc-arrow:disabled {
    opacity: 0.3;
    cursor: default;
  }

  /* ── Dots ─────────────────────────────────────────────────── */
  #tpc-section-{{ sid }} .tpc-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 20px;
  }

  #tpc-section-{{ sid }} .tpc-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    padding: 0;
    background: {{ text_color }};
    opacity: 0.28;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
  }

  #tpc-section-{{ sid }} .tpc-dot.tpc-dot--active {
    opacity: 1;
    transform: scale(1.35);
  }

  /* ── Reduced motion ───────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    #tpc-section-{{ sid }} .tpc-track {
      scroll-behavior: auto;
    }
  }
{%- endstyle -%}

<div id="tpc-section-{{ sid }}">
  <div class="tpc-inner">

    {%- if heading != blank or subheading != blank -%}
      <div class="tpc-header">
        {%- if heading != blank -%}
          <h2 class="tpc-heading {{ heading_size }}">{{ heading }}</h2>
        {%- endif -%}
        {%- if subheading != blank -%}
          <p class="tpc-subheading text-body">{{ subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="tpc-carousel-outer">
      <div class="tpc-track" id="tpc-track-{{ sid }}" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign card_bg    = block.settings.card_bg_color
            assign card_text  = block.settings.card_text_color
            assign bar_bg     = block.settings.product_bar_bg_color
            assign bar_text   = block.settings.product_bar_text_color
            assign block_product = block.settings.product
          -%}

          {%- if block_product != blank -%}
            {%- assign first_variant = block_product.first_available_variant -%}
            {%- unless first_variant -%}
              {%- assign first_variant = block_product.variants.first -%}
            {%- endunless -%}
          {%- endif -%}

          {%- capture product_img_src -%}
            {%- if block.settings.custom_product_image != blank -%}
              {{ block.settings.custom_product_image | image_url: width: 80 }}
            {%- elsif block_product != blank and block_product.featured_image != blank -%}
              {{ block_product.featured_image | image_url: width: 80 }}
            {%- endif -%}
          {%- endcapture -%}
          {%- assign product_img_src = product_img_src | strip -%}

          {%- capture product_title -%}
            {%- if block.settings.custom_product_title != blank -%}
              {{ block.settings.custom_product_title }}
            {%- elsif block_product != blank -%}
              {{ block_product.title }}
            {%- endif -%}
          {%- endcapture -%}
          {%- assign product_title = product_title | strip -%}

          <div
            class="tpc-card"
            style="background-color: {{ card_bg }}; color: {{ card_text }};"
            {{ block.shopify_attributes }}
            role="listitem"
          >
            <div class="tpc-card__body">

              {%- if block.settings.title != blank -%}
                <h3 class="tpc-card__title {{ card_title_size }}">{{ block.settings.title }}</h3>
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <p class="tpc-card__text text-body">{{ block.settings.text }}</p>
              {%- endif -%}

              <div class="tpc-card__customer">
                {%- if block.settings.customer_image != blank -%}
                  <img
                    src="{{ block.settings.customer_image | image_url: width: 72 }}"
                    alt="{{ block.settings.customer_name | escape }}"
                    width="36"
                    height="36"
                    class="tpc-card__avatar"
                    loading="lazy"
                  >
                {%- endif -%}
                <div class="tpc-card__customer-info">
                  {%- if block.settings.customer_name != blank -%}
                    <span class="tpc-card__name">{{ block.settings.customer_name }}</span>
                  {%- endif -%}
                  {%- if block.settings.customer_label != blank -%}
                    <span class="tpc-card__label">{{ block.settings.customer_label }}</span>
                  {%- endif -%}
                </div>
              </div>

            </div>

            {%- if block_product != blank -%}
              <div
                class="tpc-product-bar"
                style="background-color: {{ bar_bg }}; color: {{ bar_text }};"
              >
                <div class="tpc-product-bar__img-wrap">
                  {%- if product_img_src != blank -%}
                    <img
                      src="{{ product_img_src }}"
                      alt="{{ product_title | escape }}"
                      width="36"
                      height="36"
                      class="tpc-product-bar__img"
                      loading="lazy"
                    >
                  {%- endif -%}
                </div>

                {%- if product_title != blank -%}
                  <span class="tpc-product-bar__name">{{ product_title }}</span>
                {%- endif -%}

                {%- assign tpc_form_id = 'tpc-form-' | append: block.id -%}
                <product-form>
                  {%- form 'product', block_product,
                    id: tpc_form_id,
                    class: 'tpc-atc-form',
                    novalidate: 'novalidate',
                    data-type: 'add-to-cart-form'
                  -%}
                    <div class="hidden product-form__variants" data-values=""></div>
                    <input
                      type="hidden"
                      name="id"
                      value="{{ first_variant.id }}"
                      disabled
                      class="product-variant-id"
                    >
                    <button
                      type="submit"
                      name="add"
                      class="tpc-atc-btn"
                      aria-label="{{ block.settings.atc_button_label | default: 'Add to cart' }} – {{ product_title | escape }}"
                      {%- unless first_variant.available -%}
                        disabled
                        aria-disabled="true"
                      {%- endunless -%}
                    >
                      <span class="tpc-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                          <line x1="3" y1="6" x2="21" y2="6"/>
                          <path d="M16 10a4 4 0 0 1-8 0"/>
                        </svg>
                      </span>
                      <div class="loading-overlay__spinner hidden">
                        <svg
                          aria-hidden="true"
                          focusable="false"
                          class="spinner"
                          viewBox="0 0 66 66"
                          xmlns="http://www.w3.org/2000/svg"
                        >
                          <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                        </svg>
                      </div>
                    </button>
                  {%- endform -%}
                </product-form>

              </div>
            {%- endif -%}

          </div>
        {%- endfor -%}
      </div>
    </div>

    {%- if show_arrows and section.blocks.size > cards_visible -%}
      <div class="tpc-arrows" aria-label="{{ 'Carousel navigation' }}">
        <button class="tpc-arrow tpc-arrow--prev" id="tpc-prev-{{ sid }}" aria-label="Previous slide" disabled>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>
        <button class="tpc-arrow tpc-arrow--next" id="tpc-next-{{ sid }}" aria-label="Next slide">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
      </div>
    {%- endif -%}

    {%- if show_dots and section.blocks.size > cards_visible -%}
      <div class="tpc-dots" id="tpc-dots-{{ sid }}" role="tablist" aria-label="Carousel slides"></div>
    {%- endif -%}

  </div>
</div>

<script>
(function () {
  var section = document.getElementById('tpc-section-{{ sid }}');
  if (!section) return;

  var track = document.getElementById('tpc-track-{{ sid }}');
  if (!track) return;

  var cards = Array.prototype.slice.call(track.querySelectorAll('.tpc-card'));
  if (!cards.length) return;

  var CARDS_DESKTOP = {{ cards_visible }};
  var cardsVisible  = CARDS_DESKTOP;
  var currentIndex  = 0;

  /* ── Arrow & dot elements ─────────────────────────────── */
  var prevBtn = document.getElementById('tpc-prev-{{ sid }}');
  var nextBtn = document.getElementById('tpc-next-{{ sid }}');
  var dotsWrap = document.getElementById('tpc-dots-{{ sid }}');

  /* ── Helper: card width including gap ─────────────────── */
  function cardStep() {
    if (!cards[0]) return 0;
    var gap = parseInt(getComputedStyle(track).gap) || {{ gap }};
    return cards[0].offsetWidth + gap;
  }

  /* ── Scroll to a given index ──────────────────────────── */
  function scrollTo(index) {
    var maxIdx = Math.max(0, cards.length - cardsVisible);
    index = Math.max(0, Math.min(index, maxIdx));
    currentIndex = index;

    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    track.scrollTo({ left: index * cardStep(), behavior: reduced ? 'auto' : 'smooth' });
    syncDots();
    syncArrows();
  }

  /* ── Arrows ───────────────────────────────────────────── */
  if (prevBtn) {
    prevBtn.addEventListener('click', function () { scrollTo(currentIndex - 1); });
  }
  if (nextBtn) {
    nextBtn.addEventListener('click', function () { scrollTo(currentIndex + 1); });
  }

  function syncArrows() {
    if (prevBtn) prevBtn.disabled = currentIndex <= 0;
    if (nextBtn) nextBtn.disabled = currentIndex >= cards.length - cardsVisible;
  }

  /* ── Dots ─────────────────────────────────────────────── */
  function buildDots() {
    if (!dotsWrap) return;
    dotsWrap.innerHTML = '';
    var count = Math.max(1, cards.length - cardsVisible + 1);
    for (var i = 0; i < count; i++) {
      var dot = document.createElement('button');
      dot.className = 'tpc-dot' + (i === 0 ? ' tpc-dot--active' : '');
      dot.setAttribute('role', 'tab');
      dot.setAttribute('aria-label', 'Slide ' + (i + 1));
      dot.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
      (function (idx) {
        dot.addEventListener('click', function () { scrollTo(idx); });
      }(i));
      dotsWrap.appendChild(dot);
    }
  }

  function syncDots() {
    if (!dotsWrap) return;
    var dots = dotsWrap.querySelectorAll('.tpc-dot');
    dots.forEach(function (d, i) {
      var active = i === currentIndex;
      d.classList.toggle('tpc-dot--active', active);
      d.setAttribute('aria-selected', active ? 'true' : 'false');
    });
  }

  /* ── Sync on scroll (handles touch swipe) ─────────────── */
  var scrollTimer;
  track.addEventListener('scroll', function () {
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(function () {
      var step = cardStep();
      if (step === 0) return;
      currentIndex = Math.round(track.scrollLeft / step);
      syncDots();
      syncArrows();
    }, 80);
  }, { passive: true });

  /* ── Responsive: recalculate on resize ───────────────── */
  function onResize() {
    cardsVisible = window.innerWidth < 750 ? 1 : CARDS_DESKTOP;
    buildDots();
    syncArrows();
    /* Re-snap to current index without animation */
    track.scrollTo({ left: currentIndex * cardStep(), behavior: 'auto' });
  }

  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(onResize, 120);
  });

  /* ── Init ─────────────────────────────────────────────── */
  onResize();

  /* ── Autoplay ─────────────────────────────────────────── */
  {%- if autoplay -%}
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduced) {
    var autoTimer = null;
    function startAutoplay() {
      stopAutoplay();
      autoTimer = setInterval(function () {
        var next = currentIndex + 1;
        if (next > cards.length - cardsVisible) next = 0;
        scrollTo(next);
      }, {{ autoplay_spd }});
    }
    function stopAutoplay() {
      clearInterval(autoTimer);
    }
    startAutoplay();
    section.addEventListener('mouseenter', stopAutoplay);
    section.addEventListener('focusin', stopAutoplay);
    section.addEventListener('mouseleave', startAutoplay);
    section.addEventListener('focusout', function (e) {
      if (!section.contains(e.relatedTarget)) startAutoplay();
    });
  }
  {%- endif -%}

})();
</script>

{% schema %}
{
  "name": "Testimonial Carousel",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" },
        { "value": "h3", "label": "Small" }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading (optional)"
    },
    {
      "type": "header",
      "content": "Card typography"
    },
    {
      "type": "select",
      "id": "card_title_size",
      "label": "Card title size",
      "options": [
        { "value": "h3", "label": "Large" },
        { "value": "h4", "label": "Medium" },
        { "value": "h5", "label": "Small" }
      ],
      "default": "h4"
    },
    {
      "type": "select",
      "id": "card_text_size",
      "label": "Card body text size",
      "options": [
        { "value": "1.2rem", "label": "Small" },
        { "value": "1.5rem", "label": "Medium (theme default)" },
        { "value": "1.8rem", "label": "Large" }
      ],
      "default": "1.5rem"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Section text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width",
      "min": 600,
      "max": 1600,
      "step": 40,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "cards_per_view",
      "label": "Cards visible on desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Carousel controls"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dot indicators",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
