{% liquid
  assign product = section.settings.product
  assign bundle_size = section.settings.bundle_size | plus: 0
  assign discount_pct = section.settings.discount_pct | plus: 0

  assign first_variant = product.selected_or_first_available_variant
  assign allocations = first_variant.selling_plan_allocations
  assign allocations_count = allocations.size
  assign has_subscription = false
  if allocations_count > 0
    assign has_subscription = true
  endif

  assign money_format = shop.money_format | escape
%}

<link rel="stylesheet" href="{{ 'custom-bundle-builder.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'custom-bundle-builder.css' | asset_url }}"></noscript>
<script src="{{ 'custom-bundle-builder.js' | asset_url }}" defer></script>

{%- unless product -%}
  <div class="custom-bundle-builder__empty page-width">
    Selecteer een product in de section settings (gebruik een product met meerdere varianten als smaken).
  </div>
{%- else -%}

<custom-bundle-builder
  id="CustomBundleBuilder-{{ section.id }}"
  class="custom-bundle-builder color-{{ section.settings.color_scheme }}"
  data-product-id="{{ product.id }}"
  data-product-url="{{ product.url }}"
  data-money-format="{{ money_format }}"
  data-bundle-size="{{ bundle_size }}"
  data-discount-pct="{{ discount_pct }}"
  data-has-subscription="{{ has_subscription }}"
  data-skip-cart="{{ section.settings.skip_cart }}"
  style="
    --cbb-accent: {{ section.settings.accent_color }};
    --cbb-accent-text: {{ section.settings.accent_text_color }};
    --cbb-save-bg: {{ section.settings.save_badge_color }};
    --cbb-save-text: {{ section.settings.save_badge_text_color }};
    --cbb-radius: {{ section.settings.corner_radius }}px;
    --cbb-border-width: {{ section.settings.border_width }}px;
    --cbb-flavor-cols: {{ product.variants.size | at_most: 4 }};
    --cbb-slot-cols: {{ bundle_size | at_most: 3 }};
    padding-top: {{ section.settings.padding_top | divided_by: 10.0 }}rem;
    padding-bottom: {{ section.settings.padding_bottom | divided_by: 10.0 }}rem;
  "
>
  <div class="custom-bundle-builder__inner page-width">
    <div class="custom-bundle-builder__grid">

      <div class="custom-bundle-builder__main">
        {%- if section.settings.heading != blank -%}
          <h2 class="custom-bundle-builder__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="custom-bundle-builder__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}

        <div class="custom-bundle-builder__flavors" role="list">
          {%- for variant in product.variants -%}
            {%- assign img = variant.featured_image | default: product.featured_image -%}
            <div
              class="custom-bundle-builder__flavor"
              role="listitem"
              data-variant-id="{{ variant.id }}"
              data-variant-price="{{ variant.price }}"
              data-variant-compare="{{ variant.compare_at_price | default: 0 }}"
              data-variant-available="{{ variant.available }}"
              data-variant-title="{{ variant.title | escape }}"
              data-variant-image="{{ img | image_url: width: 200 }}"
            >
              <div class="custom-bundle-builder__flavor-media">
                {%- if img != blank -%}
                  {{ img | image_url: width: 800 | image_tag:
                       loading: 'lazy',
                       widths: '300,500,800',
                       sizes: '(min-width: 990px) 22vw, 50vw',
                       class: 'custom-bundle-builder__flavor-image',
                       alt: variant.title }}
                {%- endif -%}
              </div>
              <div class="custom-bundle-builder__flavor-name">{{ variant.title }}</div>
              <button
                type="button"
                class="custom-bundle-builder__add-btn"
                data-add-variant
                aria-label="Add {{ variant.title | escape }} to your bundle"
                {% unless variant.available %}disabled{% endunless %}
              >
                <span class="custom-bundle-builder__add-label">{{ section.settings.add_label | default: 'Add' }}</span>
              </button>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <aside class="custom-bundle-builder__summary" aria-label="Your bundle">
        <div class="custom-bundle-builder__summary-inner">
          <div class="custom-bundle-builder__status-pill" data-status-pill>
            {{ section.settings.bundle_status_label | default: 'Your bundle' }} — <span data-selected-count>0</span> / <span data-total-count>{{ bundle_size }}</span> {{ section.settings.selected_label | default: 'selected' }}
          </div>

          <div class="custom-bundle-builder__slots" data-slots>
            {%- for i in (1..bundle_size) -%}
              <div class="custom-bundle-builder__slot" data-slot-index="{{ forloop.index0 }}">
                <div class="custom-bundle-builder__slot-img" data-slot-img aria-hidden="true">
                  {%- render 'icon-3d-model' -%}
                </div>
                <button
                  type="button"
                  class="custom-bundle-builder__slot-remove"
                  data-slot-remove
                  aria-label="Remove from bundle"
                  hidden
                >
                  {%- render 'icon-close-small' -%}
                </button>
                <span class="custom-bundle-builder__slot-label">{{ section.settings.slot_label | default: 'Box' }} {{ forloop.index }}</span>
              </div>
            {%- endfor -%}
          </div>

          {%- if has_subscription -%}
            <div class="custom-bundle-builder__frequency">
              <label class="visually-hidden" for="CustomBundleFreq-{{ section.id }}">
                {{ section.settings.frequency_label | default: 'Delivery frequency' }}
              </label>
              <select
                class="custom-bundle-builder__frequency-select"
                id="CustomBundleFreq-{{ section.id }}"
                data-frequency
              >
                {%- for allocation in allocations -%}
                  <option value="{{ allocation.selling_plan.id }}" {% if forloop.first %}selected{% endif %}>
                    {{ allocation.selling_plan.name }}
                  </option>
                {%- endfor -%}
              </select>
              {%- if section.settings.frequency_helper != blank -%}
                <p class="custom-bundle-builder__frequency-helper">{{ section.settings.frequency_helper }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}

          <ul class="custom-bundle-builder__lineitems" data-lineitems hidden></ul>

          <div class="custom-bundle-builder__totals">
            <span class="custom-bundle-builder__totals-label">{{ section.settings.total_label | default: 'Total' }}</span>
            <span class="custom-bundle-builder__totals-prices">
              <span class="custom-bundle-builder__compare" data-compare hidden></span>
              <span class="custom-bundle-builder__price" data-price>{{ 0 | money }}</span>
              <span class="custom-bundle-builder__save-badge" data-save-badge hidden>
                {{ section.settings.save_label | default: 'You save' }} <span data-save-amount></span>
              </span>
            </span>
          </div>

          <button
            type="button"
            class="custom-bundle-builder__atc"
            data-atc
            data-select-more-label="{{ section.settings.select_more_label | default: 'Select more flavours' | escape }}"
            data-atc-active-label="{{ section.settings.atc_label | default: 'Add to cart' | escape }}"
            disabled
          >
            <span data-atc-label>
              {{- section.settings.select_more_label | default: 'Select more flavours' -}}
            </span>
          </button>

          <div class="custom-bundle-builder__status" data-status aria-live="polite"></div>
        </div>

        {%- if section.blocks.size > 0 -%}
          <ul class="custom-bundle-builder__trust" role="list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'trust_item' -%}
                <li class="custom-bundle-builder__trust-item" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    {{ block.settings.icon | image_url: width: 96 | image_tag:
                         loading: 'lazy',
                         widths: '48,96,144',
                         sizes: '24px',
                         class: 'custom-bundle-builder__trust-icon',
                         alt: block.settings.text | default: '' }}
                  {%- endif -%}
                  <span class="custom-bundle-builder__trust-text">{{ block.settings.text }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </aside>

    </div>
  </div>
</custom-bundle-builder>

{%- endunless -%}

{% schema %}
{
  "name": "Custom bundle builder",
  "tag": "section",
  "class": "section--custom-bundle-builder",
  "settings": [
    {
      "type": "header",
      "content": "Product source"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Bundle product",
      "info": "The product's variants become the selectable flavors. Subscription frequencies are read from the product's selling plans (same as Pack builder)."
    },
    {
      "type": "header",
      "content": "Bundle setup"
    },
    {
      "type": "range",
      "id": "bundle_size",
      "label": "Number of boxes to pick",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "discount_pct",
      "label": "Discount %",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 25,
      "info": "Visual badge + computed total. The actual checkout discount must be set up as a Shopify automatic discount."
    },
    {
      "type": "checkbox",
      "id": "skip_cart",
      "label": "Skip cart (go straight to checkout)",
      "default": false
    },
    {
      "type": "header",
      "content": "Headings & labels"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build Your Bundle"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Pick 3 boxes and get 25% off"
    },
    {
      "type": "text",
      "id": "add_label",
      "label": "Add button label",
      "default": "Add"
    },
    {
      "type": "text",
      "id": "bundle_status_label",
      "label": "Bundle status label",
      "default": "Your bundle"
    },
    {
      "type": "text",
      "id": "selected_label",
      "label": "Selected suffix",
      "default": "selected"
    },
    {
      "type": "text",
      "id": "slot_label",
      "label": "Slot label",
      "default": "Box",
      "info": "Shown under each empty slot, e.g. \"Box 1\""
    },
    {
      "type": "text",
      "id": "frequency_label",
      "label": "Frequency field label (a11y)",
      "default": "Delivery frequency"
    },
    {
      "type": "text",
      "id": "frequency_helper",
      "label": "Frequency helper text",
      "default": "Electrolytes recur on your schedule."
    },
    {
      "type": "text",
      "id": "total_label",
      "label": "Total label",
      "default": "Total"
    },
    {
      "type": "text",
      "id": "save_label",
      "label": "Save badge prefix",
      "default": "You save"
    },
    {
      "type": "text",
      "id": "select_more_label",
      "label": "Disabled ATC label",
      "default": "Select more flavours"
    },
    {
      "type": "text",
      "id": "atc_label",
      "label": "Active ATC label",
      "default": "Add to cart"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "inverse", "label": "Inverse" }
      ],
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (ATC, selected)",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "accent_text_color",
      "label": "Accent text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "save_badge_color",
      "label": "Save badge background",
      "default": "#C8FF3D"
    },
    {
      "type": "color",
      "id": "save_badge_text_color",
      "label": "Save badge text",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon",
          "info": "Recommended: small SVG/PNG, ~48x48px."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Binnen 24u verzonden"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Custom bundle builder",
      "blocks": [
        { "type": "trust_item", "settings": { "text": "Binnen 24 uur verzonden" } },
        { "type": "trust_item", "settings": { "text": "60 dagen garantie" } },
        { "type": "trust_item", "settings": { "text": "Van Europese bodem" } }
      ]
    }
  ]
}
{% endschema %}
