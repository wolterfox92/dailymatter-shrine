{%- liquid
  assign sid = section.id
  assign heading        = section.settings.heading
  assign heading_size   = section.settings.heading_size
  assign subheading     = section.settings.subheading
  assign alignment      = section.settings.alignment
  assign section_bg     = section.settings.section_bg_color
  assign card_bg        = section.settings.card_bg_color
  assign text_color     = section.settings.text_color
  assign active_color   = section.settings.active_color
  assign inactive_color = section.settings.inactive_color
  assign card_max_w     = section.settings.card_max_width
  assign img_ratio      = section.settings.image_aspect_ratio
  assign pt             = section.settings.padding_top
  assign pb             = section.settings.padding_bottom
-%}

{%- style -%}
  #it-section-{{ sid }} {
    background-color: {{ section_bg }};
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
  }
  #it-section-{{ sid }} .it-inner {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Shared heading styles ──────────────────────────── */
  #it-section-{{ sid }} .it-heading {
    margin: 0 0 12px;
    color: {{ active_color }};
  }
  #it-section-{{ sid }} .it-subheading {
    margin: 0;
    color: {{ active_color }};
    opacity: 0.6;
    max-width: 480px;
  }

  /* ── Ingredient list ────────────────────────────────── */
  #it-section-{{ sid }} .it-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  #it-section-{{ sid }} .it-list__item { line-height: 1; }
  #it-section-{{ sid }} .it-list__btn {
    display: block;
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    padding: 5px 0;
    text-align: left;
  }
  #it-section-{{ sid }} .it-list__name {
    display: block;
    font-family: var(--font-heading-family);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
    transition: color 0.2s ease, font-weight 0.15s ease;
  }

  /* ── Card ───────────────────────────────────────────── */
  #it-section-{{ sid }} .it-card {
    width: 100%;
    background: {{ card_bg }};
    border-radius: 24px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr;
  }
  #it-section-{{ sid }} .it-card__media {
    overflow: hidden;
  }
  {%- if img_ratio == 'square' -%}
  #it-section-{{ sid }} .it-card__media { aspect-ratio: 1/1; }
  {%- elsif img_ratio == 'portrait' -%}
  #it-section-{{ sid }} .it-card__media { aspect-ratio: 3/4; }
  {%- elsif img_ratio == 'landscape' -%}
  #it-section-{{ sid }} .it-card__media { aspect-ratio: 4/3; }
  {%- else -%}
  #it-section-{{ sid }} .it-card__media { aspect-ratio: auto; min-height: 240px; }
  {%- endif -%}
  #it-section-{{ sid }} .it-card__media img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  #it-section-{{ sid }} .it-card__content {
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  #it-section-{{ sid }} .it-card__title {
    margin: 0;
    color: {{ text_color }};
    line-height: 1.2;
  }
  #it-section-{{ sid }} .it-card__desc {
    margin: 0;
    color: {{ text_color }};
    opacity: 0.8;
    font-size: 1.5rem;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }
  #it-section-{{ sid }} .it-card__desc p { margin: 0; }
  #it-section-{{ sid }} .it-card__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 1.3rem;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: 600;
    color: {{ text_color }};
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    opacity: 0.65;
    transition: opacity 0.2s ease;
    width: fit-content;
  }
  #it-section-{{ sid }} .it-card__link:hover { opacity: 1; }
  #it-section-{{ sid }} .it-card__link svg {
    width: 13px; height: 13px;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }
  #it-section-{{ sid }} .it-card__link:hover svg { transform: translate(2px, -2px); }

  /* Panel visibility */
  #it-section-{{ sid }} .it-card[data-panel] { display: none; }
  #it-section-{{ sid }} .it-card[data-panel].is-active { display: grid; }

  #it-section-{{ sid }} .it-card.is-active {
    animation: it-fadein 0.28s ease both;
  }
  @keyframes it-fadein {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ═══════════════════════════════════════════════════
     DESKTOP  ≥ 990px — two column layout
  ═══════════════════════════════════════════════════ */
  @media screen and (min-width: 990px) {
    #it-section-{{ sid }} .it-body {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-areas: "left right";
      gap: 0 80px;
      align-items: start;
    }
    #it-section-{{ sid }} .it-col-left {
      grid-area: left;
    }
    #it-section-{{ sid }} .it-col-right {
      grid-area: right;
      position: sticky;
      top: 40px;
    }
    /* Mobile-only active title: hidden on desktop */
    #it-section-{{ sid }} .it-mobile-active { display: none; }

    /* Header inside left column */
    #it-section-{{ sid }} .it-header-inner {
      margin-bottom: 36px;
      text-align: {{ alignment }};
    }

    /* Desktop ingredient list */
    #it-section-{{ sid }} .it-list { gap: 0; }
    #it-section-{{ sid }} .it-list__btn { padding: 4px 0; }
    #it-section-{{ sid }} .it-list__name {
      font-size: clamp(2.4rem, 3vw, 3.6rem);
      color: {{ inactive_color }};
      font-weight: 400;
    }
    /* Active ingredient: bold + dark */
    #it-section-{{ sid }} .it-list__btn[aria-selected="true"] .it-list__name {
      color: {{ active_color }};
      font-weight: 700;
    }
    /* Hover highlight (inactive items) */
    #it-section-{{ sid }} .it-list__btn:not([aria-selected="true"]):hover .it-list__name {
      color: {{ active_color }};
      opacity: 0.55;
    }
    /* On desktop the active tab is fully visible — remove sr-only styling */
    #it-section-{{ sid }} .it-list__btn[aria-selected="true"] {
      position: static;
      width: auto; height: auto;
      padding: 4px 0;
      margin: 0;
      overflow: visible;
      clip: auto;
      white-space: normal;
    }

    /* Desktop card: tall single-column */
    #it-section-{{ sid }} .it-card {
      border-radius: 20px;
      grid-template-columns: 1fr;
    }
    {%- if img_ratio == 'auto' -%}
    #it-section-{{ sid }} .it-card__media { min-height: 420px; aspect-ratio: auto; }
    {%- else -%}
    #it-section-{{ sid }} .it-card__media { min-height: unset; }
    {%- endif -%}
    #it-section-{{ sid }} .it-card__content {
      padding: 28px 28px 32px;
    }
  }

  /* ═══════════════════════════════════════════════════
     MOBILE  < 990px — stacked layout
     Active name → card → inactive list
  ═══════════════════════════════════════════════════ */
  @media screen and (max-width: 989px) {
    #it-section-{{ sid }} .it-body {
      display: flex;
      flex-direction: column;
    }
    /* Flatten left column so its children participate in flex ordering */
    #it-section-{{ sid }} .it-col-left { display: contents; }
    /* Order: header → active name → card → inactive list */
    #it-section-{{ sid }} .it-header-inner { order: 1; margin-bottom: 20px; text-align: {{ alignment }}; }
    #it-section-{{ sid }} .it-mobile-active { order: 2; }
    #it-section-{{ sid }} .it-col-right { order: 3; }
    #it-section-{{ sid }} .it-list { order: 4; margin-top: 20px; }

    /* Active name above card on mobile */
    #it-section-{{ sid }} .it-mobile-active {
      width: 100%;
      font-family: var(--font-heading-family);
      font-weight: 700;
      font-size: clamp(3.2rem, 10vw, 4.8rem);
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: {{ active_color }};
      margin-bottom: 14px;
    }

    /* Mobile card */
    #it-section-{{ sid }} .it-card {
      border-radius: 20px;
      grid-template-columns: 1fr;
      margin-bottom: 0;
    }
    {%- if img_ratio == 'auto' -%}
    #it-section-{{ sid }} .it-card__media { min-height: 220px; aspect-ratio: 4/3; }
    {%- endif -%}
    #it-section-{{ sid }} .it-card__content { padding: 22px 18px; gap: 10px; }

    /* Mobile ingredient list (inactive names below card) */
    #it-section-{{ sid }} .it-list__btn { padding: 3px 0; }
    #it-section-{{ sid }} .it-list__name {
      font-size: clamp(2rem, 5vw, 2.6rem);
      color: {{ inactive_color }};
      font-weight: 400;
    }
    #it-section-{{ sid }} .it-list__btn:hover .it-list__name {
      color: {{ active_color }};
      opacity: 0.6;
    }
    /* Active tab is sr-only on mobile (name is shown in .it-mobile-active instead) */
    #it-section-{{ sid }} .it-list__btn[aria-selected="true"] {
      position: absolute;
      width: 1px; height: 1px;
      padding: 0; margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }
{%- endstyle -%}

<div
  id="it-section-{{ sid }}"
  class="it-section animate-section animate--hidden{% if section.settings.section_bg_color == 'rgba(0,0,0,0)' or section.settings.section_bg_color == blank %} color-{{ section.settings.color_scheme }}{% endif %}"
>
  <div class="it-inner">
    <ingredient-tabs class="it-body" data-section="{{ sid }}">

      {{- '<!-- Left column: heading + ingredient list -->' }}
      <div class="it-col-left animate-item animate-item--child" style="--index: 0;">

        {%- if heading != blank or subheading != blank -%}
          <div class="it-header-inner">
            {%- if heading != blank -%}
              <h2 class="it-heading {{ heading_size }}">{{ heading }}</h2>
            {%- endif -%}
            {%- if subheading != blank -%}
              <p class="it-subheading text-body">{{ subheading }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}

        <ul
          class="it-list"
          role="tablist"
          aria-label="{{ heading | default: 'Ingredients' | escape }}"
        >
          {%- for block in section.blocks -%}
            {%- liquid
              assign is_first = forloop.first
              assign panel_id = 'it-panel-' | append: sid | append: '-' | append: forloop.index0
              assign tab_id   = 'it-tab-'   | append: sid | append: '-' | append: forloop.index0
            -%}
            <li class="it-list__item" role="presentation">
              <button
                id="{{ tab_id }}"
                class="it-list__btn"
                role="tab"
                aria-selected="{% if is_first %}true{% else %}false{% endif %}"
                aria-controls="{{ panel_id }}"
                data-index="{{ forloop.index0 }}"
                data-name="{{ block.settings.name | default: 'Ingredient' | escape }}"
                tabindex="{% if is_first %}0{% else %}-1{% endif %}"
              >
                <span class="it-list__name">{{ block.settings.name | default: 'Ingredient' }}</span>
              </button>
            </li>
          {%- endfor -%}
        </ul>

      </div>

      {{- '<!-- Mobile: active ingredient name displayed above card (JS-updated) -->' }}
      <div class="it-mobile-active" aria-hidden="true">
        {{- section.blocks.first.settings.name | default: '' -}}
      </div>

      {{- '<!-- Right column: card panels -->' }}
      <div class="it-col-right animate-item animate-item--child" style="--index: 1;">
        {%- for block in section.blocks -%}
          {%- liquid
            assign is_first = forloop.first
            assign panel_id = 'it-panel-' | append: sid | append: '-' | append: forloop.index0
            assign tab_id   = 'it-tab-'   | append: sid | append: '-' | append: forloop.index0
          -%}
          <div
            id="{{ panel_id }}"
            class="it-card{% if is_first %} is-active{% endif %}"
            role="tabpanel"
            aria-labelledby="{{ tab_id }}"
            data-panel="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              <div class="it-card__media">
                {{
                  block.settings.image
                  | image_url: width: 900
                  | image_tag:
                    loading: 'lazy',
                    alt: block.settings.image_alt | default: block.settings.card_title,
                    widths: '400,600,900',
                    sizes: '(max-width: 989px) 100vw, 50vw'
                }}
              </div>
            {%- else -%}
              <div class="it-card__media" style="background: rgba(0,0,0,0.06);"></div>
            {%- endif -%}
            <div class="it-card__content">
              {%- if block.settings.card_title != blank -%}
                <h3 class="it-card__title h4">{{ block.settings.card_title }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <div class="it-card__desc">{{ block.settings.description }}</div>
              {%- endif -%}
              {%- if block.settings.study_url != blank and block.settings.study_label != blank -%}
                <a
                  class="it-card__link"
                  href="{{ block.settings.study_url }}"
                  {% if block.settings.link_new_tab %}target="_blank" rel="noopener"{% endif %}
                >
                  {{ block.settings.study_label }}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 17L17 7M7 7h10v10"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>

    </ingredient-tabs>
  </div>
</div>

<script>
(function() {
  if (customElements.get('ingredient-tabs')) return;

  class IngredientTabs extends HTMLElement {
    connectedCallback() {
      this._tabs      = Array.from(this.querySelectorAll('[role="tab"]'));
      this._panels    = Array.from(this.querySelectorAll('[role="tabpanel"]'));
      this._mobileTitle = this.querySelector('.it-mobile-active');
      this._hoverTimer  = null;

      this._tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          clearTimeout(this._hoverTimer);
          this._select(parseInt(tab.dataset.index, 10));
        });
        // Hover (desktop): 120ms delay so fast mouse movements don't flash
        tab.addEventListener('mouseenter', () => {
          clearTimeout(this._hoverTimer);
          this._hoverTimer = setTimeout(() => {
            this._select(parseInt(tab.dataset.index, 10));
          }, 120);
        });
        tab.addEventListener('mouseleave', () => {
          clearTimeout(this._hoverTimer);
        });
        tab.addEventListener('keydown', e => this._onKey(e));
      });
    }

    _select(index) {
      const current = this._tabs.findIndex(t => t.getAttribute('aria-selected') === 'true');
      if (current === index) return;

      if (current >= 0) {
        this._tabs[current].setAttribute('aria-selected', 'false');
        this._tabs[current].setAttribute('tabindex', '-1');
        this._panels[current].classList.remove('is-active');
      }

      this._tabs[index].setAttribute('aria-selected', 'true');
      this._tabs[index].setAttribute('tabindex', '0');
      this._panels[index].classList.add('is-active');

      // Update mobile active title
      if (this._mobileTitle) {
        this._mobileTitle.textContent = this._tabs[index].dataset.name || '';
      }
    }

    _onKey(e) {
      const total = this._tabs.length;
      const current = this._tabs.findIndex(t => t.getAttribute('aria-selected') === 'true');
      let next = current;

      switch (e.key) {
        case 'ArrowDown':
        case 'ArrowRight':
          e.preventDefault(); next = (current + 1) % total; break;
        case 'ArrowUp':
        case 'ArrowLeft':
          e.preventDefault(); next = (current - 1 + total) % total; break;
        case 'Home':
          e.preventDefault(); next = 0; break;
        case 'End':
          e.preventDefault(); next = total - 1; break;
        default: return;
      }

      clearTimeout(this._hoverTimer);
      this._select(next);
      this._tabs[next].focus({ preventScroll: true });
    }
  }

  customElements.define('ingredient-tabs', IngredientTabs);
})();
</script>

{% schema %}
{
  "name": "Ingredient tabs",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Key ingredients"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "H1 (largest)" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4 (smallest)" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme (fallback)",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "inverse", "label": "Inverse" }
      ],
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background color",
      "default": "#c8f135"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Card text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "active_color",
      "label": "Active ingredient name color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "inactive_color",
      "label": "Inactive ingredient name color",
      "default": "#cccccc"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "card_max_width",
      "label": "Card max width (desktop, px)",
      "min": 500,
      "max": 1200,
      "step": 20,
      "default": 1200
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "square",    "label": "Square (1:1)" },
        { "value": "portrait",  "label": "Portrait (3:4)" },
        { "value": "landscape", "label": "Landscape (4:3)" },
        { "value": "auto",      "label": "Auto (fill height)" }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Ingredient name (shown in list)",
          "default": "Ingredient name"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card title (shown inside card)",
          "default": "Ingredient title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>A short explanation of what this ingredient does and why it matters.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text"
        },
        {
          "type": "text",
          "id": "study_label",
          "label": "Study link label",
          "default": "View study"
        },
        {
          "type": "url",
          "id": "study_url",
          "label": "Study URL"
        },
        {
          "type": "checkbox",
          "id": "link_new_tab",
          "label": "Open link in new tab",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredient tabs",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "name": "Mentha Spicata",
            "card_title": "Mentha Spicata",
            "description": "<p>Spearmint extract shown to support hormonal balance and reduce androgen levels in clinical studies.</p>",
            "study_label": "Lees studie",
            "link_new_tab": true
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Pantotheenzuur",
            "card_title": "Pantotheenzuur (500mg)",
            "description": "<p>Vitamine B5 draagt bij aan normale synthese en het normale metabolisme van steroidhormonen en sommige neurotransmitters.</p>",
            "study_label": "Lees studie",
            "link_new_tab": true
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Vitamine A",
            "card_title": "Vitamine A",
            "description": "<p>Vitamine A speelt een sleutelrol bij de celvernieuwing van de huid en ondersteunt een normale talgproductie.</p>",
            "study_label": "Lees studie",
            "link_new_tab": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
