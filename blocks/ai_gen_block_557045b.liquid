{% doc %}
  @prompt
    Add padding_top and padding_bottom range settings to the Product carousel section (section ID: template--29812733313349__177823763496eabb6b, block ID: template--29812733313349__177823763496eabb6b__ai_gen_block_5ce8385_cxBBWz). The settings should appear as sliders in the theme editor so the merchant can control the top and bottom vertical spacing of the section. Apply sensible defaults (e.g. 40px each).
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-carousel-{{ ai_gen_id }} {
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    width: 100%;
  }

  .ai-product-carousel-container-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
  }

  .ai-product-carousel-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-product-carousel-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-product-carousel-item-{{ ai_gen_id }} {
    flex: 0 0 300px;
    scroll-snap-align: start;
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 20px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-product-carousel-image-{{ ai_gen_id }} {
    width: 100%;
    height: 300px;
    object-fit: cover;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: 15px;
  }

  .ai-product-carousel-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 10px;
    color: {{ block.settings.text_color }};
  }

  .ai-product-carousel-price-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.price_color }};
    margin-bottom: 15px;
  }

  .ai-product-carousel-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 10px 20px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: background-color 0.3s ease;
  }

  .ai-product-carousel-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-product-carousel-item-{{ ai_gen_id }} {
      flex: 0 0 250px;
    }
  }
{% endstyle %}

<div class="ai-product-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-carousel-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 style="text-align: {{ block.settings.heading_alignment }}; margin-bottom: 30px; color: {{ block.settings.heading_color }};">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    <div class="ai-product-carousel-wrapper-{{ ai_gen_id }}">
      {% if block.settings.collection != blank %}
        {% for product in block.settings.collection.products limit: block.settings.products_to_show %}
          <div class="ai-product-carousel-item-{{ ai_gen_id }}">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                class="ai-product-carousel-image-{{ ai_gen_id }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {% else %}
              <div class="ai-product-carousel-image-{{ ai_gen_id }}" style="background-color: #f4f4f4; display: flex; align-items: center; justify-content: center;">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}

            <h3 class="ai-product-carousel-title-{{ ai_gen_id }}">{{ product.title }}</h3>
            <div class="ai-product-carousel-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
            <a href="{{ product.url }}" class="ai-product-carousel-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
          </div>
        {% endfor %}
      {% else %}
        <div style="padding: 40px; text-align: center; color: #666;">
          <p>Select a collection to display products</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product carousel",
  "settings": [
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View product"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#6d388b"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#6d388b"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#e0ffb6"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "Product carousel"
    }
  ]
}
{% endschema %}
