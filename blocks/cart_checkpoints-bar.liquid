      "label": "Mobile labels text size",
      "info": "Mobile font size of goal names under icons"
    },
    {
      "type": "range",
      "id": "labels_desktop_text_size",
      "min": 6,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12,
      "label": "Desktop labels text size",
      "info": "Desktop font size of goal names under icons"
    },
    {
      "type": "header",
