{% liquid
  assign non_upsell_count = cart.item_count
  for item in cart.items
    if item.product.tags contains 'cart-hidden'
      assign non_upsell_count = non_upsell_count | minus: item.quantity
    endif
  endfor
%}

{% render 'cart-progress-bar', block: block, items_count: non_upsell_count %}

{% schema %}
{
  "name": "Progress bar",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Goal"
    },
    {
      "type": "paragraph",
      "content": "Use the progress bar for shipping or other cart promotions. The progress bar will show a success message once the customer reaches the set goal. If needed, make sure to set up an [automatic discount](https://help.shopify.com/en/manual/discounts/automatic-discounts)."
    },
    {
      "type": "select",
      "id": "goal_type",
      "options": [
        {
          "value": "subtotal",
          "label": "Cart subtotal price"
        },
        {
          "value": "quantity",
          "label": "Quantity of added cart items"
        }
      ],
      "label": "Base the goal on",
      "default": "subtotal",
      "info": "Determines if the goal will be based on the total cart subtotal price, or the total quantity of items added to cart (excluding the items with the \"cart-hidden\" tag)."
    },
    {
      "type": "number",
      "id": "goal",
      "label": "Progress bar goal",
      "info": "Required cart subtotal/quantity for the promotion.",
      "default": 50
    },
    {
      "type": "checkbox",
      "id": "sub_auto_complete",
      "default": false,
      "label": "Complete the goal if a subscription has been added",
      "info": "Automatically mark the progress as comppleted if a subscription has been added to cart, no matter the subtotal/quantity of added items."
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "progress_message",
      "label": "Progress message",
      "default": "Spend [amount] more to get FREE shipping!",
      "info": "Use '[amount]' to display the amount/quantity needed to reach the goal."
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Congrats! You get FREE shipping!"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 16,
      "max": 50,
      "step": 2,
      "label": "Size",
      "default": 30,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "icon_type",
      "label": "Icon",
      "options": [
        { "value": "icon", "label": "Icon" },
        { "value": "custom_icon", "label": "Custom icon" },
        { "value": "dot", "label": "Dot" },
        { "value": "none", "label": "None" }
      ],
      "default": "icon"
    },
    {
      "type": "text",
      "id": "icon",
      "default": "local_shipping",
      "label": "Icon",
      "info": "[View all available icons](https://fonts.google.com/icons?icon.set=Material+Symbols&icon.platform=web).",
      "visible_if": "{{ block.settings.icon_type == 'icon' }}"
    },
    {
      "type": "checkbox",
      "id": "icon_filled",
      "default": false,
      "label": "Filled icon",
      "visible_if": "{{ block.settings.icon_type == 'icon' }}"
    },
    {
      "type": "image_picker",
      "id": "custom_icon",
      "label": "Custom icon",
      "visible_if": "{{ block.settings.icon_type == 'custom_icon' }}"
    },
    {
      "type": "range",
      "id": "icon_scale",
      "min": 30,
      "max": 90,
      "step": 5,
      "label": "Icon scale",
      "default": 60,
      "unit": "%",
      "visible_if": "{{ block.settings.icon_type != 'none' }}"
    },
    {
      "type": "select",
      "id": "icon_color",
      "label": "Icon color",
      "options": [
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "outline-button", "label": "Outline button" },
        { "value": "text", "label": "Text" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "accent-1",
      "visible_if": "{{ block.settings.icon_type != 'custom_icon' and block.settings.icon_type != 'none' }}"
    },
    {
      "type": "color",
      "id": "icon_custom_color",
      "label": "Icon color",
      "default": "#DD1D1D",
      "visible_if": "{{ block.settings.icon_color == 'custom' }}"
    },
    {
      "type": "select",
      "id": "icon_bg",
      "label": "Background color",
      "options": [
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "text", "label": "Text" },
        { "value": "custom_color", "label": "Custom color" },
        { "value": "gradient", "label": "Gradient" }
      ],
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Background color",
      "default": "#ececec",
      "visible_if": "{{ block.settings.icon_bg == 'custom_color' }}"
    },
    {
      "type": "color_background",
      "id": "icon_bg_gradient",
      "label": "Background gradient",
      "default": "linear-gradient(89deg, rgba(249, 234, 255, 1) 7%, rgba(218, 197, 255, 1) 94%)",
      "visible_if": "{{ block.settings.icon_bg == 'gradient' }}"
    },
    {
      "type": "range",
      "id": "border_thickness",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "label": "Border thickness",
      "default": 2,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border style",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" }
      ],
      "default": "solid",
      "visible_if": "{{ block.settings.border_thickness > 0 }}"
    },
    {
      "type": "select",
      "id": "border_color",
      "label": "Border color",
      "options": [
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "outline-button", "label": "Outline button" },
        { "value": "text", "label": "Text" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "accent-1",
      "visible_if": "{{ block.settings.border_thickness > 0 }}"
    },
    {
      "type": "color",
      "id": "border_custom_color",
      "label": "Border color",
      "default": "#DD1D1D",
      "visible_if": "{{ block.settings.border_thickness > 0 and block.settings.border_color == 'custom' }}"
    },
    {
      "type": "range",
      "id": "icon_corner_radius",
      "min": 0,
      "max": 100,
      "step": 5,
      "label": "Corner radius",
      "default": 100,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Line"
    },
    {
      "type": "range",
      "id": "line_height",
      "min": 2,
      "max": 15,
      "step": 1,
      "label": "Line height",
      "default": 9,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "display_stripes",
      "label": "Display stripes animation",
      "default": true,
      "visible_if": "{{ block.settings.line_color != 'gradient' }}"
    },
    {
      "type": "select",
      "id": "line_color",
      "label": "Line color",
      "options": [
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "outline-button", "label": "Outline button" },
        { "value": "text", "label": "Text" },
        { "value": "custom_color", "label": "Custom color" },
        { "value": "gradient", "label": "Gradient" }
      ],
      "default": "accent-1"
    },
    {
      "type": "color",
      "id": "line_custom_color",
      "label": "Line color",
      "default": "#DD1D1D",
      "visible_if": "{{ block.settings.line_color == 'custom_color' }}"
    },
    {
      "type": "color_background",
      "id": "line_gradient",
      "label": "Line gradient",
      "default": "linear-gradient(57deg, rgba(249, 119, 255, 1) 8%, rgba(54, 212, 255, 1) 47%, rgba(43, 252, 135, 1) 83%)",
      "visible_if": "{{ block.settings.line_color == 'gradient' }}"
    },
    {
      "type": "header",
      "content": "Block margin"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "label": "Top margin",
      "default": 15
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "label": "Bottom margin",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "Progress bar"
    }
  ]
}
{% endschema %}
