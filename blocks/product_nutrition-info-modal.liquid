{%- liquid
  assign block_id = block.id
  assign unique_class = 'nim-' | append: block_id | replace: '_', '-'
  assign modal_id = 'NutritionInfoModal-' | append: block_id
  assign trigger_id = 'NutritionInfoTrigger-' | append: block_id
  assign has_image = false
  if block.settings.modal_image != blank
    assign has_image = true
  endif
-%}

{%- if has_image -%}
  {%- style -%}
    .{{ unique_class }}__wrapper {
      padding-top: {{ block.settings.spacing_top }}px;
      padding-bottom: {{ block.settings.spacing_bottom }}px;
      text-align: {{ block.settings.alignment }};
    }

    .{{ unique_class }}__trigger {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: transparent;
      border: 0;
      padding: 0.2rem 0;
      margin: 0;
      cursor: pointer;
      font: inherit;
      color: {{ block.settings.text_color }};
      line-height: 1.4;
      -webkit-tap-highlight-color: transparent;
    }

    .{{ unique_class }}__trigger:hover .{{ unique_class }}__label,
    .{{ unique_class }}__trigger:focus-visible .{{ unique_class }}__label {
      opacity: 0.75;
    }

    .{{ unique_class }}__trigger:focus { outline: none; }
    .{{ unique_class }}__trigger:focus-visible {
      outline: 2px solid {{ block.settings.text_color }};
      outline-offset: 3px;
      border-radius: 2px;
    }

    .{{ unique_class }}__icon {
      flex: 0 0 auto;
      width: 1.4rem;
      height: 1.4rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .{{ unique_class }}__icon svg {
      width: 100%;
      height: 100%;
      display: block;
      fill: none;
      stroke: currentColor;
      stroke-width: 1.5;
    }

    .{{ unique_class }}__label {
      text-decoration: underline;
      text-underline-offset: 3px;
      transition: opacity 0.15s ease;
    }

    .{{ unique_class }}__overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 }});
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease;
      z-index: 100000;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.6rem;
      box-sizing: border-box;
    }

    .{{ unique_class }}__overlay[data-open="true"] {
      opacity: 1;
      pointer-events: auto;
    }

    .{{ unique_class }}__dialog {
      position: relative;
      background: {{ block.settings.modal_background_color }};
      border-radius: {{ block.settings.modal_border_radius }}px;
      width: 100%;
      max-width: {{ block.settings.modal_max_width }}px;
      max-height: calc(100vh - 4rem);
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
      transform: translateY(12px) scale(0.98);
      transition: transform 0.25s ease;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .{{ unique_class }}__overlay[data-open="true"] .{{ unique_class }}__dialog {
      transform: translateY(0) scale(1);
    }

    .{{ unique_class }}__close {
      position: absolute;
      top: 1.2rem;
      right: 1.2rem;
      width: 3.6rem;
      height: 3.6rem;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.95);
      border: 0;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
      z-index: 2;
      color: #111;
      transition: transform 0.15s ease, background 0.15s ease;
    }

    .{{ unique_class }}__close:hover { background: #fff; transform: scale(1.05); }
    .{{ unique_class }}__close:focus { outline: none; }
    .{{ unique_class }}__close:focus-visible {
      outline: 2px solid #111;
      outline-offset: 2px;
    }

    .{{ unique_class }}__close svg {
      width: 1.4rem;
      height: 1.4rem;
      stroke: currentColor;
      stroke-width: 2;
      fill: none;
    }

    .{{ unique_class }}__media {
      width: 100%;
      max-height: calc(100vh - 4rem);
      overflow: auto;
      -webkit-overflow-scrolling: touch;
    }

    .{{ unique_class }}__media img {
      display: block;
      width: 100%;
      height: auto;
      max-height: calc(100vh - 4rem);
      object-fit: contain;
    }

    @media (max-width: 749px) {
      .{{ unique_class }}__overlay { padding: 1.2rem; }
      .{{ unique_class }}__dialog { max-height: calc(100vh - 2.4rem); }
      .{{ unique_class }}__close {
        width: 3.2rem;
        height: 3.2rem;
        top: 0.8rem;
        right: 0.8rem;
      }
      .{{ unique_class }}__media,
      .{{ unique_class }}__media img { max-height: calc(100vh - 2.4rem); }
    }
  {%- endstyle -%}

  <div class="{{ unique_class }}__wrapper" {{ block.shopify_attributes }}>
    <button
      type="button"
      id="{{ trigger_id }}"
      class="{{ unique_class }}__trigger"
      aria-haspopup="dialog"
      aria-controls="{{ modal_id }}"
      aria-expanded="false"
      data-nim-trigger="{{ block_id }}"
    >
      {%- if block.settings.show_icon -%}
        <span class="{{ unique_class }}__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="9.25" />
            <line x1="12" y1="10.5" x2="12" y2="16.5" stroke-linecap="round" />
            <circle cx="12" cy="7.5" r="0.9" fill="currentColor" stroke="none" />
          </svg>
        </span>
      {%- endif -%}
      <span class="{{ unique_class }}__label">{{ block.settings.link_text }}</span>
    </button>

    <div
      id="{{ modal_id }}"
      class="{{ unique_class }}__overlay"
      data-nim-overlay="{{ block_id }}"
      data-open="false"
      hidden
    >
      <div
        role="dialog"
        aria-modal="true"
        aria-labelledby="{{ trigger_id }}"
        class="{{ unique_class }}__dialog"
        tabindex="-1"
        data-nim-dialog
      >
        <button
          type="button"
          class="{{ unique_class }}__close"
          data-nim-close
          aria-label="{{ 'accessibility.close' | t | default: 'Close' }}"
        >
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <line x1="6" y1="6" x2="18" y2="18" stroke-linecap="round" />
            <line x1="18" y1="6" x2="6" y2="18" stroke-linecap="round" />
          </svg>
        </button>
        <div class="{{ unique_class }}__media">
          {%- assign img_alt = block.settings.image_alt_text | default: block.settings.modal_image.alt | default: block.settings.link_text -%}
          <img
            src="{{ block.settings.modal_image | image_url: width: 1600 }}"
            srcset="{{ block.settings.modal_image | image_url: width: 600 }} 600w, {{ block.settings.modal_image | image_url: width: 1000 }} 1000w, {{ block.settings.modal_image | image_url: width: 1600 }} 1600w, {{ block.settings.modal_image | image_url: width: 2000 }} 2000w"
            sizes="(max-width: 749px) 92vw, min({{ block.settings.modal_max_width }}px, 92vw)"
            alt="{{ img_alt | escape }}"
            width="{{ block.settings.modal_image.width }}"
            height="{{ block.settings.modal_image.height }}"
            loading="lazy"
            decoding="async"
          >
        </div>
      </div>
    </div>
  </div>

  <script>
    (function () {
      var BLOCK_ID = {{ block_id | json }};
      var trigger = document.getElementById({{ trigger_id | json }});
      var overlay = document.getElementById({{ modal_id | json }});
      if (!trigger || !overlay) return;
      if (trigger.dataset.nimBound === '1') return;
      trigger.dataset.nimBound = '1';

      var dialog = overlay.querySelector('[data-nim-dialog]');
      var closeBtn = overlay.querySelector('[data-nim-close]');
      var lastFocus = null;
      var scrollY = 0;

      function lockScroll() {
        scrollY = window.scrollY || window.pageYOffset || 0;
        document.body.style.position = 'fixed';
        document.body.style.top = '-' + scrollY + 'px';
        document.body.style.left = '0';
        document.body.style.right = '0';
        document.body.style.width = '100%';
      }

      function unlockScroll() {
        document.body.style.position = '';
        document.body.style.top = '';
        document.body.style.left = '';
        document.body.style.right = '';
        document.body.style.width = '';
        window.scrollTo(0, scrollY);
      }

      function open() {
        lastFocus = document.activeElement;
        overlay.hidden = false;
        // force reflow so the transition runs
        void overlay.offsetWidth;
        overlay.setAttribute('data-open', 'true');
        trigger.setAttribute('aria-expanded', 'true');
        lockScroll();
        document.addEventListener('keydown', onKeydown);
        // focus dialog so screen readers announce it
        setTimeout(function () { if (dialog) dialog.focus(); }, 50);
      }

      function close() {
        overlay.setAttribute('data-open', 'false');
        trigger.setAttribute('aria-expanded', 'false');
        document.removeEventListener('keydown', onKeydown);
        unlockScroll();
        var onEnd = function () {
          overlay.hidden = true;
          overlay.removeEventListener('transitionend', onEnd);
        };
        overlay.addEventListener('transitionend', onEnd);
        // fallback if transitionend doesn't fire
        setTimeout(function () { overlay.hidden = true; }, 400);
        if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
      }

      function onKeydown(e) {
        if (e.key === 'Escape' || e.keyCode === 27) {
          e.preventDefault();
          close();
        }
      }

      trigger.addEventListener('click', function (e) {
        e.preventDefault();
        open();
      });

      closeBtn.addEventListener('click', function (e) {
        e.preventDefault();
        close();
      });

      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) close();
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Nutrition info modal",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "View nutritional information"
    },
    {
      "type": "image_picker",
      "id": "modal_image",
      "label": "Modal image",
      "info": "If no image is set, the clickable row is hidden."
    },
    {
      "type": "text",
      "id": "image_alt_text",
      "label": "Image alt text"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show info icon",
      "default": true
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Link text color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Modal"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 95,
      "step": 5,
      "unit": "%",
      "default": 60
    },
    {
      "type": "color",
      "id": "modal_background_color",
      "label": "Modal background color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "modal_max_width",
      "label": "Modal max width (desktop)",
      "min": 320,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 720
    },
    {
      "type": "range",
      "id": "modal_border_radius",
      "label": "Modal border radius",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Spacing top",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Spacing bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Nutrition info modal",
      "category": "Product information"
    }
  ]
}
{% endschema %}
